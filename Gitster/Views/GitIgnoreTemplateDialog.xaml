<Window x:Class="Gitster.Views.GitIgnoreTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Append .gitignore template"
        Width="520"
        Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundPrimary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ComboBox x:Name="TemplateBox"
                  ItemsSource="{Binding TemplateNames}"
                  SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                  SelectionChanged="TemplateBox_SelectionChanged"/>

        <TextBox Grid.Row="2"
                 x:Name="PreviewBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="{StaticResource FontFamilyMono}"
                 Text="{Binding PreviewText}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    MinWidth="86"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Style="{StaticResource GhostButton}"/>
            <Button Content="Append"
                    MinWidth="86"
                    IsDefault="True"
                    Click="Append_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
