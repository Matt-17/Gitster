<UserControl x:Class="Gitster.Views.Modes.WorktreesModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:converters="clr-namespace:Gitster.Converters"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <converters:InverseBoolVisibilityConverter x:Key="InverseBoolVis"/>
    </UserControl.Resources>

    <Grid DataContext="{Binding WorktreesVM}"
          d:DataContext="{d:DesignInstance Type=vm:WorktreesViewModel}">

        <!-- "Requires Git CLI" state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"
                    Visibility="{Binding IsCliAvailable, Converter={StaticResource InverseBoolVis}}">
            <TextBlock Text="Worktrees require the Git command-line tool"
                       FontSize="15" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
            <TextBlock Text="Install Git for Windows and restart Gitster to use worktrees."
                       FontSize="12" Margin="0,6,0,0"
                       Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Main layout (CLI available) -->
        <Grid Visibility="{Binding IsCliAvailable, Converter={StaticResource BoolVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="320" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,10,10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Worktrees" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Prune…" Style="{StaticResource GhostButton}" Padding="10,4"
                                Margin="0,0,4,0" Command="{Binding PruneCommand}"
                                ToolTip="Remove stale worktree entries"/>
                        <Button Content="Add worktree…" Style="{StaticResource GhostButton}" Padding="10,4"
                                Command="{Binding AddCommand}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"
                            Visibility="{Binding HasWorktrees, Converter={StaticResource InverseBoolVis}}">
                    <TextBlock Text="No worktrees" FontSize="15"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Worktrees}"
                          SelectedItem="{Binding SelectedWorktree}"
                          Background="Transparent" BorderThickness="0"
                          Visibility="{Binding HasWorktrees, Converter={StaticResource BoolVis}}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="6,5"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                                 Fill="{StaticResource AccentBlue}"
                                                 Visibility="{Binding IsCurrent, Converter={StaticResource BoolVis}}"/>
                                        <TextBlock Text="{Binding BranchName}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" FontSize="11"
                                               FontFamily="{StaticResource FontFamilyMono}"
                                               Foreground="{StaticResource TextTertiary}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="3" Padding="5,1" Margin="3,0,0,0"
                                            Background="{StaticResource AccentInfoBackground}"
                                            Visibility="{Binding IsMain, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="main" FontSize="10" Foreground="{StaticResource AccentBlue}"/>
                                    </Border>
                                    <Border CornerRadius="3" Padding="5,1" Margin="3,0,0,0"
                                            Background="{StaticResource AccentWarningBackground}"
                                            Visibility="{Binding IsLocked, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="locked" FontSize="10" Foreground="{StaticResource AccentWarning}"/>
                                    </Border>
                                    <Border CornerRadius="3" Padding="5,1" Margin="3,0,0,0"
                                            Background="{StaticResource AccentDangerBackground}"
                                            Visibility="{Binding IsPrunable, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="missing" FontSize="10" Foreground="{StaticResource AccentDanger}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderTertiary}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right column: actions -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel>
                    <TextBlock Text="Select a worktree"
                               FontSize="13" Foreground="{StaticResource TextTertiary}"
                               HorizontalAlignment="Center" Margin="0,40,0,0"
                               Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolVis}}"/>

                    <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolVis}}">
                        <Border Style="{StaticResource PanelCard}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedWorktree.BranchName}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedWorktree.Path}"
                                           FontSize="11" FontFamily="{StaticResource FontFamilyMono}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedWorktree.ShortSha}"
                                           FontSize="11" FontFamily="{StaticResource FontFamilyMono}"
                                           Foreground="{StaticResource TextTertiary}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Open in Gitster"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding OpenInGitsterCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Open folder"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding OpenInExplorerCommand}" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="Remove"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding RemoveCommand}"
                                    Foreground="{StaticResource AccentDanger}" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
