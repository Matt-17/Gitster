<Window x:Class="Gitster.Views.RepositoryLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Gitster.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:RepositoryLoadingViewModel}"
        Title="{Binding TitleText}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimary}"
        Closing="Window_Closing">
    <Border Padding="18"
            BorderBrush="{DynamicResource BorderTertiary}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding TitleText}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>

            <TextBlock Grid.Row="1"
                       Text="{Binding RepositoryPath}"
                       Margin="0,6,0,14"
                       FontFamily="{DynamicResource FontFamilyMono}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource TextSecondary}"/>

            <ProgressBar Grid.Row="2"
                         Height="8"
                         Margin="0,0,0,14"
                         Minimum="0"
                         Maximum="{Binding ProgressMaximum}"
                         Value="{Binding ProgressValue}"/>

            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding StageText}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding CounterText}"
                           Margin="16,0,0,0"
                           FontFamily="{DynamicResource FontFamilyMono}"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="{Binding DetailText}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}"/>
            </Grid>

            <DockPanel Grid.Row="4">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ElapsedText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextTertiary}"
                           FontFamily="{DynamicResource FontFamilyMono}"/>
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Width="92"
                        Height="30"
                        HorizontalAlignment="Right"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding CanCancel}"
                        Style="{DynamicResource GhostButton}"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
