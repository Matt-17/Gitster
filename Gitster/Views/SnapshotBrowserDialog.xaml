<Window x:Class="Gitster.Views.SnapshotBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapshots"
        Width="680"
        Height="430"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundPrimary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView ItemsSource="{Binding Snapshots}"
                  SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}"
                  BorderBrush="{DynamicResource BorderTertiary}"
                  BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Captured" Width="150" DisplayMemberBinding="{Binding CapturedAt}"/>
                    <GridViewColumn Header="Trigger" Width="260" DisplayMemberBinding="{Binding TriggerDescription}"/>
                    <GridViewColumn Header="Refs" Width="60" DisplayMemberBinding="{Binding RefStates.Count}"/>
                    <GridViewColumn Header="Id" Width="160" DisplayMemberBinding="{Binding Id}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close"
                    IsCancel="True"
                    MinWidth="86"
                    Margin="0,0,8,0"
                    Style="{StaticResource GhostButton}"/>
            <Button Content="Restore current branch"
                    MinWidth="140"
                    Margin="0,0,8,0"
                    Click="RestoreBranch_Click"
                    Style="{StaticResource GhostButton}"/>
            <Button Content="Restore all refs"
                    MinWidth="120"
                    Click="RestoreAll_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
