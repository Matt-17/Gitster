<Window x:Class="Gitster.Views.NewStashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="New stash"
        Width="440" Height="200"
        MinWidth="360" MinHeight="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message label -->
        <TextBlock Grid.Row="0"
                   Text="Message (optional):"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondary}"/>

        <!-- Message TextBox -->
        <TextBox Grid.Row="2"
                 x:Name="MessageTextBox"
                 FontSize="13"
                 Padding="6,4"
                 Background="{DynamicResource BackgroundSecondary}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource BorderTertiary}"/>

        <!-- Include untracked checkbox -->
        <CheckBox Grid.Row="4"
                  x:Name="UntrackedCheck"
                  IsChecked="True"
                  FontSize="12"
                  Foreground="{DynamicResource TextPrimary}"
                  Content="Include untracked files"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{DynamicResource GhostButton}"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="Stash"
                    Style="{DynamicResource PrimaryButton}"
                    Width="80"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
