<Window x:Class="Gitster.Views.AuthorRepairDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Gitster.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:AuthorRepairViewModel}"
        mc:Ignorable="d"
        Title="Repair author"
        Width="540" Height="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Padding="16" Background="{DynamicResource BackgroundPrimary}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Find row -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Find commits by"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Authors}"
                          SelectedItem="{Binding FindAuthor}"
                          DisplayMemberPath="DisplayName"
                          Height="28" FontSize="12"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource BorderTertiary}"/>
            </Grid>

            <!-- Replace row -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Replace with"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Authors}"
                          SelectedItem="{Binding ReplaceAuthor}"
                          DisplayMemberPath="DisplayName"
                          Height="28" FontSize="12"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource BorderTertiary}"/>
            </Grid>

            <!-- Options -->
            <CheckBox Grid.Row="2"
                      Content="Also update committer"
                      IsChecked="{Binding AlsoUpdateCommitter}"
                      Foreground="{DynamicResource TextSecondary}"
                      FontSize="12"
                      Margin="0,0,0,12"/>

            <!-- Warning: unsafe commits -->
            <Border Grid.Row="3"
                    Visibility="{Binding HasUnsafeCommits, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{DynamicResource AccentWarningBackground}"
                    BorderBrush="{DynamicResource AccentWarning}"
                    BorderThickness="0.5"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Padding="10,7"
                    Margin="0,0,0,10">
                <TextBlock TextWrapping="Wrap" FontSize="12">
                    <Run Text="⚠" Foreground="{DynamicResource AccentWarning}"/>
                    <Run Text=" Some of the affected commits are already on the remote. Rewriting will require a force-push."
                         Foreground="{DynamicResource TextPrimary}"/>
                </TextBlock>
            </Border>

            <!-- Affected commits list -->
            <Grid Grid.Row="4" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,4">
                    <Run Text="Affected commits: "/>
                    <Run Text="{Binding AffectedCommits.Count, Mode=OneWay}"/>
                </TextBlock>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding AffectedCommits}"
                         Background="{DynamicResource BackgroundSecondary}"
                         BorderBrush="{DynamicResource BorderTertiary}"
                         BorderThickness="0.5"
                         FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Sha}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Message}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="5"
                       Text="Loading…"
                       Foreground="{DynamicResource TextTertiary}"
                       FontSize="12"
                       Margin="0,0,0,10"
                       Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="30" Margin="0,0,8,0"
                        Click="OnCancel"
                        IsCancel="True"
                        Style="{StaticResource GhostButton}"/>
                <Button Content="Rewrite commits" Height="30" Padding="12,0"
                        Command="{Binding RewriteCommand}"
                        IsEnabled="{Binding IsRewriteEnabled}"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
