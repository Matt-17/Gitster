<Window x:Class="Gitster.Views.SnapshotBranchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Snapshot to branch"
        Width="460" Height="220"
        MinWidth="400" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Branch name"
                   FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox Grid.Row="2" x:Name="NameBox"
                 FontSize="13"
                 Background="{DynamicResource BackgroundSecondary}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource BorderTertiary}"/>

        <CheckBox Grid.Row="4" x:Name="IncludeUncommittedCheck"
                  Content="Include uncommitted changes"
                  IsChecked="True"
                  Foreground="{DynamicResource TextSecondary}" FontSize="12"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{DynamicResource GhostButton}" Width="80"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Create" Style="{DynamicResource PrimaryButton}" Width="90"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
