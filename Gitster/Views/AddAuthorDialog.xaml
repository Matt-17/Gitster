<Window x:Class="Gitster.Views.AddAuthorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add author"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
    </Window.Resources>

    <Border Padding="16" Background="{StaticResource BackgroundPrimary}">
        <StackPanel>

            <Label Content="Name"/>
            <TextBox x:Name="NameBox" Margin="0,0,0,10"/>

            <Label Content="Email"/>
            <TextBox x:Name="EmailBox" Margin="0,0,0,10"/>

            <CheckBox x:Name="GlobalCheck"
                      Content="Add to global .gitconfig"
                      Foreground="{StaticResource TextSecondary}"
                      FontSize="12"
                      Margin="0,0,0,16"/>

            <!-- Error text -->
            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource AccentDanger}"
                       FontSize="11"
                       Visibility="Collapsed"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="30" Margin="0,0,8,0"
                        Click="OnCancel"
                        Style="{StaticResource GhostButton}"/>
                <Button Content="Add" Width="80" Height="30"
                        Click="OnAdd"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
