<Window x:Class="Gitster.Views.ManageToolsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Gitster.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ManageToolsViewModel}"
        mc:Ignorable="d"
        Title="Manage custom tools"
        Width="720" Height="500"
        MinWidth="600" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: tool list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0"
                     ItemsSource="{Binding Tools}"
                     SelectedItem="{Binding SelectedTool}"
                     Background="{DynamicResource BackgroundSecondary}"
                     BorderBrush="{DynamicResource BorderTertiary}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding Scope}" FontSize="10"
                                       Foreground="{DynamicResource TextTertiary}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="New tool"
                    Style="{DynamicResource GhostButton}"
                    Command="{Binding NewCommand}"
                    HorizontalAlignment="Stretch"/>
        </Grid>

        <!-- Right: edit form -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4" Margin="0,4,0,10"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>

                <TextBlock Text="Command" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4" Margin="0,4,0,2"
                         FontFamily="{DynamicResource FontFamilyMono}"
                         AcceptsReturn="False"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>
                <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Text="Placeholders: $REVISION/$CUR (selected commit), $ARGS (prompt value), $BRANCH, $REPO"/>

                <TextBlock Text="Confirmation prompt (optional)" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Text="{Binding Confirm, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4" Margin="0,4,0,10"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>

                <TextBlock Text="Argument prompt (optional → $ARGS)" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="6,4" Margin="0,4,0,10"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>

                <CheckBox Content="Requires a selected commit (passes its SHA as $REVISION)"
                          IsChecked="{Binding NeedsCommit}"
                          Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

                <TextBlock Text="Scope" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                    <RadioButton x:Name="GlobalRadio" Content="Global" GroupName="scope"
                                 IsChecked="True"
                                 Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"/>
                    <RadioButton Content="This repository" GroupName="scope"
                                 IsChecked="{Binding IsRepoScope}"
                                 IsEnabled="{Binding RepositoryAvailable}"
                                 Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Templates:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextTertiary}" Margin="0,0,8,0"/>
                    <Button Content="Feature branch" Style="{DynamicResource GhostButton}" Padding="8,3" Margin="0,0,4,0"
                            Command="{Binding TemplateFeatureBranchCommand}"/>
                    <Button Content="Open on GitHub" Style="{DynamicResource GhostButton}" Padding="8,3" Margin="0,0,4,0"
                            Command="{Binding TemplateOpenOnGitHubCommand}"/>
                    <Button Content="Run tests" Style="{DynamicResource GhostButton}" Padding="8,3"
                            Command="{Binding TemplateRunTestsCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Delete" Style="{DynamicResource GhostButton}" Width="90"
                            Margin="0,0,8,0" Foreground="{DynamicResource AccentDanger}"
                            Command="{Binding DeleteCommand}"/>
                    <Button Content="Save" Style="{DynamicResource PrimaryButton}" Width="90"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
