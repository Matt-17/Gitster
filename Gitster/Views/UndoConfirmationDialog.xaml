<Window x:Class="Gitster.Views.UndoConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Confirm undo"
        Width="520" Height="320"
        MinWidth="400" MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Warning header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Path Width="16" Height="16" Stretch="Uniform"
                  Fill="{DynamicResource AccentWarning}"
                  Data="M12,2 L22,21 H2 Z M12,9 V14 M12,17 V18"
                  VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="This undo will discard commits"
                       FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="2"
                   Text="The following commits were made after the operation you are undoing. Choose what to do with them:"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="12" TextWrapping="Wrap"/>

        <!-- Commit list -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource BorderTertiary}"
                BorderThickness="0.5"
                CornerRadius="4"
                Background="{DynamicResource BackgroundSecondary}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl x:Name="CommitList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Sha}"
                                           FontFamily="{DynamicResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Width="56"/>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    IsDefault="False" IsCancel="True"
                    Style="{StaticResource GhostButton}"
                    Padding="16,6" Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="ReplayButton"
                    Content="Replay on top"
                    Style="{StaticResource GhostButton}"
                    Padding="16,6" Margin="0,0,8,0"
                    Click="ReplayButton_Click"/>
            <Button x:Name="DiscardButton"
                    Content="Discard commits"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButton}"
                    Padding="16,6"
                    Click="DiscardButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
