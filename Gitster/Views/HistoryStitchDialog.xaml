<Window x:Class="Gitster.Views.HistoryStitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stitch history"
        Width="640" Height="620"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Stitch history"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="Create one merge commit that records the old branch as history while keeping the current files unchanged."
                       Margin="0,4,0,0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="10,8"
                Background="{DynamicResource BackgroundSecondary}"
                BorderBrush="{DynamicResource BorderTertiary}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Source history"
                               FontSize="10"
                               Foreground="{DynamicResource TextTertiary}"/>
                    <TextBlock x:Name="SourceBranchText"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text=" into "
                           Margin="10,16"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Current branch"
                               FontSize="10"
                               Foreground="{DynamicResource TextTertiary}"/>
                    <TextBlock x:Name="TargetBranchText"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource AccentBlue}"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Command"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="CommandText"
                     IsReadOnly="True"
                     FontFamily="{DynamicResource FontFamilyMono}"
                     FontSize="12"
                     Padding="8,5"
                     TextWrapping="NoWrap"
                     BorderBrush="{DynamicResource BorderTertiary}"
                     Background="{DynamicResource BackgroundSecondary}"
                     Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Preview"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="0,0,0,4"/>
                <Border Padding="10,8"
                        Background="{DynamicResource BackgroundSecondary}"
                        BorderBrush="{DynamicResource BorderTertiary}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock x:Name="GraphText"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               Foreground="{DynamicResource TextPrimary}"/>
                </Border>

                <Border x:Name="BlocksBox"
                        Padding="10,8"
                        Margin="0,10,0,0"
                        Background="{DynamicResource AccentDangerBackground}"
                        BorderBrush="{DynamicResource AccentDanger}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Cannot stitch yet"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentDanger}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl x:Name="BlockList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border x:Name="WarningsBox"
                        Padding="10,8"
                        Margin="0,10,0,0"
                        Background="{DynamicResource AccentWarningBackground}"
                        BorderBrush="{DynamicResource AccentWarning}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Warnings"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentWarning}"
                                   Margin="0,0,0,4"/>
                        <ItemsControl x:Name="WarningList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Padding="10,8"
                        Margin="0,10,0,0"
                        Background="{DynamicResource AccentInfoBackground}"
                        BorderBrush="{DynamicResource AccentBlue}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="Undo before push: use Gitster undo/reset or the backup branch. Undo after push: revert the merge commit with git revert -m 1 &lt;merge-commit&gt; instead of resetting published history."
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{DynamicResource GhostButton}"
                    Width="90"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button x:Name="StitchButton"
                    Content="Stitch history"
                    Style="{DynamicResource PrimaryButton}"
                    Width="120"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
