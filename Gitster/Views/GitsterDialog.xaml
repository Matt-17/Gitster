<Window x:Class="Gitster.Views.GitsterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="620"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        KeyboardNavigation.TabNavigation="Cycle">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundPrimary}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CornerRadiusMd}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{DynamicResource AccentBlue}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CaptionText"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextOnAccent}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1"
                        Width="42"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextOnAccent}"
                        Click="OnCloseClicked"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Close"
                        AutomationProperties.Name="Close dialog">
                    <TextBlock Text="x"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="18,18,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="32"
                        Height="32"
                        CornerRadius="16"
                        Background="{DynamicResource AccentInfoBackground}"
                        Margin="0,0,14,0"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBlue}"/>
                </Border>
                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="19"
                           MaxWidth="520"/>
            </Grid>

            <StackPanel x:Name="ButtonsHost"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="18,0,18,18"/>
        </Grid>
    </Border>
</Window>
