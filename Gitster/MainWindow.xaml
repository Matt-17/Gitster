<Window x:Class="Gitster.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:vm="clr-namespace:Gitster.ViewModels"
       xmlns:models="clr-namespace:Gitster.Models"
       xmlns:controls="clr-namespace:Gitster.Controls"
       xmlns:modes="clr-namespace:Gitster.Views.Modes"
       xmlns:helper="clr-namespace:Gitster.Views.Helper"
       xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
       d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
       mc:Ignorable="d"
       WindowStyle="None"
       ResizeMode="CanResize"
       Title="{Binding WindowTitle}" Height="850" Width="1100" ContentRendered="Window_ContentRendered" Activated="Window_Activated"
       Icon="pack://application:,,,/Gitster;component/Assets/Icon.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.InputBindings>
        <KeyBinding Key="O"  Modifiers="Ctrl" Command="{Binding BrowseFolderCommand}"/>
        <KeyBinding Key="K"  Modifiers="Ctrl" Command="{Binding OpenCommitPanelCommand}"/>
        <KeyBinding Key="F"  Modifiers="Ctrl" Command="{Binding CommitListVM.FocusSearchCommand}"/>
        <KeyBinding Key="OemQuestion" Modifiers="Ctrl" Command="{Binding OpenShortcutsCommand}"/>
        <KeyBinding Key="F1" Command="{Binding OpenShortcutsCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl+Shift" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Key="Z"  Modifiers="Ctrl" Command="{Binding UndoBarVM.UndoCommand}"/>
        <KeyBinding Key="F5"                  Command="{Binding FetchCommand}"/>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding AmendCommitCommand}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Commits}"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Stashes}"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Branches}"/>
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Worktrees}"/>
        <KeyBinding Key="D5" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Search}"/>
        <KeyBinding Key="D6" Modifiers="Ctrl" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.OperationsLog}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- ── Menu theming ──────────────────────────────────────────────────
             Top-level items sit on the accent bar (white text, transparent bg);
             submenu popups are fully themed so text stays readable in light and
             dark. NOTE: Foreground is an inherited property, so the white text on
             the top-level headers would otherwise bleed into the submenu items and
             render white-on-light-gray — the templates below reset it explicitly. -->

        <!-- Reusable themed submenu popup around an ItemsPresenter. -->
        <ControlTemplate x:Key="SubmenuItemTemplate" TargetType="MenuItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="0"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="Check" Grid.Column="0" Text="&#xE73E;"
                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource AccentBlue}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" Margin="2,6,12,6"/>
                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Submenu header: leaf layout + a nested (Right-placed) themed popup. -->
        <ControlTemplate x:Key="SubmenuHeaderTemplate" TargetType="MenuItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="0"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" Margin="2,6,12,6"/>
                    <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Right" HorizontalOffset="-2" VerticalOffset="-3"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource BackgroundPrimary}"
                                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="3" Margin="0,0,8,8" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Top-level header on the accent bar: white text + themed dropdown popup. -->
        <ControlTemplate x:Key="TopLevelHeaderTemplate" TargetType="MenuItem">
            <Border x:Name="Bd" Background="Transparent" Padding="10,0" SnapsToDevicePixels="True">
                <Grid>
                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      TextElement.Foreground="White"/>
                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Bottom" VerticalOffset="1" PopupAnimation="Fade">
                        <Border Background="{DynamicResource BackgroundPrimary}"
                                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="3" Margin="0,0,8,8" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ChromeMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template" Value="{StaticResource SubmenuItemTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template" Value="{StaticResource TopLevelHeaderTemplate}"/>
                </Trigger>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template" Value="{StaticResource SubmenuHeaderTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Themed separator inside the popups. -->
        <Style x:Key="ChromeMenuSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{DynamicResource WindowBorderBrush}" Opacity="0.6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseChromeButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeCloseHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeClosePressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootContainer"
            Background="{DynamicResource BackgroundPrimary}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <DockPanel>
            <!-- ── Custom-chrome top bar (accent) ───────────────────────────── -->
            <Grid DockPanel.Dock="Top" Height="38" Background="{DynamicResource AccentBlue}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="pack://application:,,,/Gitster;component/Assets/Icon.ico"
                       Width="18" Height="18" Margin="10,0,8,0" VerticalAlignment="Center"/>

                <Menu Grid.Column="1" Background="Transparent" VerticalAlignment="Center"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Menu.Resources>
                        <!-- Submenu children inherit the themed template (top-level items set it explicitly). -->
                        <Style TargetType="MenuItem" BasedOn="{StaticResource ChromeMenuItem}"/>
                        <Style TargetType="Separator" BasedOn="{StaticResource ChromeMenuSeparator}"/>
                    </Menu.Resources>
                    <MenuItem Header="_File" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Open repository..." Command="{Binding BrowseFolderCommand}" InputGestureText="Ctrl+O"/>
                        <MenuItem Header="Recent" ItemsSource="{Binding RecentRepos}">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource ChromeMenuItem}">
                                    <Setter Property="Header" Value="{Binding DisplayPath}"/>
                                    <Setter Property="ToolTip" Value="{Binding FullPath}"/>
                                    <Setter Property="Command" Value="{Binding DataContext.OpenRepoCommand, RelativeSource={RelativeSource AncestorType=Menu}}"/>
                                    <Setter Property="CommandParameter" Value="{Binding FullPath}"/>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Options..." Command="{Binding OpenOptionsCommand}"/>
                        <Separator/>
                        <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
                    </MenuItem>

                    <MenuItem Header="_Repository" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Commit..." Command="{Binding OpenCommitPanelCommand}" InputGestureText="Ctrl+K"/>
                        <MenuItem Header="Archive current HEAD..."
                                  helper:Capability.Requires="SourceArchive"
                                  Command="{Binding ArchiveHeadCommand}"/>
                        <MenuItem Header="Append .gitignore template..."
                                  Command="{Binding AppendGitIgnoreTemplateCommand}"/>
                        <Separator/>
                        <MenuItem Header="Fetch"   Command="{Binding FetchCommand}" InputGestureText="F5"/>
                        <MenuItem Header="Pull"    Command="{Binding PullCommand}"/>
                        <MenuItem Header="Push"    Command="{Binding PushCommand}"/>
                        <MenuItem Header="Sync"    Command="{Binding SyncCommand}"/>
                        <Separator/>
                        <MenuItem Header="Switch branch..."      Command="{Binding SwitchBranchCommand}"/>
                        <Separator/>
                        <MenuItem Header="Operations log..."     Command="{Binding OpenOperationsLogCommand}"/>
                        <MenuItem Header="Snapshots..."          Command="{Binding OpenSnapshotBrowserCommand}"/>
                        <MenuItem Header="Repository settings..." Command="{Binding OpenRepoSettingsCommand}"/>
                        <Separator/>
                        <MenuItem Header="Repair author..."           Command="{Binding OpenAuthorRepairCommand}"/>
                        <MenuItem Header="Rewrite timestamps..."      Command="{Binding OpenRewriteTimestampsCommand}"/>
                    </MenuItem>

                    <MenuItem Header="_Edit" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Undo"    Command="{Binding UndoBarVM.UndoCommand}" InputGestureText="Ctrl+Z"/>
                        <Separator/>
                        <MenuItem Header="Find in commits" Command="{Binding CommitListVM.FocusSearchCommand}" InputGestureText="Ctrl+F"/>
                        <MenuItem Header="Search mode" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Search}" InputGestureText="Ctrl+5"/>
                    </MenuItem>

                    <MenuItem Header="_View" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5"/>
                        <Separator/>
                        <MenuItem Header="_Commits"        Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Commits}"      InputGestureText="Ctrl+1"/>
                        <MenuItem Header="_Stashes"        Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Stashes}"      InputGestureText="Ctrl+2"/>
                        <MenuItem Header="B_ranches"       Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Branches}"     InputGestureText="Ctrl+3"/>
                        <MenuItem Header="_Worktrees"      Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Worktrees}"    InputGestureText="Ctrl+4"/>
                        <MenuItem Header="S_earch"         Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.Search}"       InputGestureText="Ctrl+5"/>
                        <MenuItem Header="Operations _log" Command="{Binding SidebarVM.SelectModeCommand}" CommandParameter="{x:Static models:AppMode.OperationsLog}" InputGestureText="Ctrl+6"/>
                        <Separator/>
                        <MenuItem Header="Relative dates" IsCheckable="True" IsChecked="{Binding Ui.UseRelativeDates}"/>
                        <MenuItem Header="Show avatars (Gravatar)" IsCheckable="True" IsChecked="{Binding Ui.GravatarEnabled}"
                                  ToolTip="Fetches avatars from Gravatar using a hash of the author email."/>
                        <Separator/>
                        <MenuItem Header="Theme">
                            <MenuItem Header="Light"
                                      IsCheckable="True"
                                      IsChecked="{Binding Ui.IsLightTheme, Mode=OneWay}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static models:ThemePreference.Light}"/>
                            <MenuItem Header="Dark"
                                      IsCheckable="True"
                                      IsChecked="{Binding Ui.IsDarkTheme, Mode=OneWay}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static models:ThemePreference.Dark}"/>
                            <MenuItem Header="Follow Windows"
                                      IsCheckable="True"
                                      IsChecked="{Binding Ui.IsSystemTheme, Mode=OneWay}"
                                      Command="{Binding SetThemeCommand}"
                                      CommandParameter="{x:Static models:ThemePreference.System}"/>
                        </MenuItem>
                    </MenuItem>

                    <MenuItem Header="_Tools" x:Name="ToolsMenu" SubmenuOpened="ToolsMenu_SubmenuOpened" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Manage tools…" Command="{Binding ManageToolsCommand}"/>
                    </MenuItem>

                    <MenuItem Header="_Help" Style="{StaticResource ChromeMenuItem}">
                        <MenuItem Header="Documentation"       Command="{Binding OpenDocsCommand}"/>
                        <MenuItem Header="Keyboard shortcuts"  Command="{Binding OpenShortcutsCommand}"/>
                        <MenuItem Header="Command palette"     Command="{Binding OpenCommandPaletteCommand}" InputGestureText="Ctrl+Shift+P"/>
                        <Separator/>
                        <MenuItem Header="Enable update checks" IsCheckable="True" IsChecked="{Binding Ui.UpdateChecksEnabled}"/>
                        <MenuItem Header="Enable persistent diagnostic logs" IsCheckable="True" IsChecked="{Binding Ui.PersistentLoggingEnabled}"
                                  ToolTip="Writes diagnostic log files after the next restart."/>
                        <MenuItem Header="Check for updates" Command="{Binding CheckForUpdatesCommand}"/>
                        <Separator/>
                        <MenuItem Header="About Gitster"       Command="{Binding OpenAboutCommand}"/>
                    </MenuItem>
                </Menu>

                <!-- App + repo identity (muted, right of center) -->
                <TextBlock Grid.Column="2" Text="{Binding WindowTitle}" VerticalAlignment="Center"
                           HorizontalAlignment="left" Margin="24,0"
                           Foreground="{DynamicResource TitleMutedOnAccent}" FontSize="12" TextTrimming="CharacterEllipsis"/>

                <!-- Window controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource ChromeButton}" Click="OnMinimize" ToolTip="Minimize"
                            AutomationProperties.Name="Minimize window">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" Click="OnMaxRestore" ToolTip="Maximize/Restore"
                            AutomationProperties.Name="Maximize or restore window">
                        <TextBlock x:Name="MaxRestoreGlyph" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseChromeButton}" Click="OnCloseWindow" ToolTip="Close"
                            AutomationProperties.Name="Close window">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Neutral toolbar (A3/A4/A11) ──────────────────────────────── -->
            <controls:Toolbar DockPanel.Dock="Top"/>

            <!-- ── Ops-log line (A7, always present) ────────────────────────── -->
            <controls:UndoBar DockPanel.Dock="Top" DataContext="{Binding UndoBarVM}"/>

            <!-- ── Status bar ───────────────────────────────────────────────── -->
            <controls:StatusBar x:Name="StatusBarControl" DockPanel.Dock="Bottom" DataContext="{Binding StatusBarVM}"/>

            <!-- Commit panel flyout (A2), anchored above the status-bar working-tree text -->
            <Popup PlacementTarget="{Binding ElementName=StatusBarControl}"
                   Placement="Top" HorizontalOffset="8" VerticalOffset="-2"
                   AllowsTransparency="True" PopupAnimation="Fade"
                   StaysOpen="True"
                   IsOpen="{Binding CommitPanelVM.IsOpen, Mode=TwoWay}">
                <controls:CommitPanel DataContext="{Binding CommitPanelVM}" Margin="8">
                    <controls:CommitPanel.InputBindings>
                        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding CommitAndPushCommand}"/>
                        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
                    </controls:CommitPanel.InputBindings>
                </controls:CommitPanel>
            </Popup>

            <!-- Main content: sidebar + mode content area -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:Sidebar Grid.Column="0" DataContext="{Binding SidebarVM}"/>

                <Grid Grid.Column="1">
                    <modes:CommitsModeView
                        Visibility="{Binding SidebarVM.IsCommitsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <modes:StashesModeView
                        Visibility="{Binding SidebarVM.IsStashesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <modes:BranchesModeView
                        Visibility="{Binding SidebarVM.IsBranchesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <modes:WorktreesModeView
                        Visibility="{Binding SidebarVM.IsWorktreesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <modes:SearchModeView
                        Visibility="{Binding SidebarVM.IsSearchActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <modes:OperationsLogModeView
                        Visibility="{Binding SidebarVM.IsOperationsLogActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
