<UserControl x:Class="Gitster.Controls.Toolbar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">
    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="DropItemButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- A pinned/recent repo row: name + path (opens repo) and a pin toggle -->
        <DataTemplate x:Key="RepoDropItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource DropItemButton}" Click="ClosePopup"
                        Command="{Binding DataContext.OpenRepoCommand, ElementName=Root}"
                        CommandParameter="{Binding FullPath}" ToolTip="{Binding FullPath}">
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}"
                                   FontWeight="Medium" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding DisplayPath}" Foreground="{StaticResource TextSecondary}"
                                   FontFamily="{StaticResource FontFamilyMono}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Width="26" Height="26" Padding="5" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Command="{Binding DataContext.TitleBarVM.TogglePinRepoCommand, ElementName=Root}"
                        CommandParameter="{Binding FullPath}" ToolTip="{Binding PinTooltip}">
                    <Path Width="13" Height="13" Stretch="Uniform"
                          Data="M8,1 L12,5 L10,7 L12,10 L10,12 L7,9 L3,13 L1,11 L5,7 L2,4 L4,2 L7,5 Z"
                          StrokeThickness="1.2" StrokeLineJoin="Round">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                <Setter Property="Fill" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource AccentBlue}"/>
                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundSecondary}"
            BorderBrush="{StaticResource BorderTertiary}" BorderThickness="0,0,0,0.5"
            Padding="8,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── A4: Switch-repo dropdown ──────────────────────────────── -->
            <ToggleButton x:Name="RepoToggle" Grid.Column="0" Height="28" Margin="0,0,6,0"
                          Background="Transparent" BorderBrush="{StaticResource BorderSecondary}"
                          BorderThickness="1" Padding="8,2" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TitleBarVM.RepositoryName}" VerticalAlignment="Center"
                               FontWeight="Medium" Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    <Path Width="8" Height="5" Margin="6,0,0,0" Data="M0,0 L4,4 L8,0"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Popup Grid.Column="0" PlacementTarget="{Binding ElementName=RepoToggle}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=RepoToggle, Mode=TwoWay}">
                <Border Width="340" Background="{StaticResource BackgroundPrimary}"
                        BorderBrush="{StaticResource BorderTertiary}" BorderThickness="1"
                        CornerRadius="8" Padding="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.22" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Current repo header (not clickable) -->
                        <Border Background="{StaticResource AccentBlueBackground}" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📂" FontSize="13" VerticalAlignment="Top" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TitleBarVM.RepositoryName}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding TitleBarVM.CurrentRepositoryPath}" FontSize="10"
                                               FontFamily="{StaticResource FontFamilyMono}"
                                               Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="✓" Foreground="{StaticResource AccentBlue}"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Pinned -->
                        <TextBlock Text="Pinned" FontSize="10" FontWeight="SemiBold" Margin="8,4,0,2"
                                   Foreground="{StaticResource TextTertiary}"
                                   Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TitleBarVM.PinnedItems}"
                                      ItemTemplate="{StaticResource RepoDropItemTemplate}"
                                      Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Separator Margin="4,4"
                                   Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Recent -->
                        <TextBlock Text="Recent" FontSize="10" FontWeight="SemiBold" Margin="8,2,0,2"
                                   Foreground="{StaticResource TextTertiary}"
                                   Visibility="{Binding TitleBarVM.HasRecentOnly, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TitleBarVM.RecentItems}"
                                      ItemTemplate="{StaticResource RepoDropItemTemplate}"
                                      Visibility="{Binding TitleBarVM.HasRecentOnly, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Separator Margin="4,4"/>
                        <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                Command="{Binding BrowseFolderCommand}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="Ctrl+O" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                                <TextBlock Text="📁  Browse repository…" Foreground="{StaticResource TextPrimary}"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ── A11: Branch dropdown ──────────────────────────────────── -->
            <ToggleButton x:Name="BranchToggle" Grid.Column="1" Height="28" Margin="0,0,12,0"
                          Background="Transparent" BorderBrush="{StaticResource BorderSecondary}"
                          BorderThickness="1" Padding="8,2" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5" Fill="Transparent"
                          Data="M6,3 a2,2 0 1,0 0.01,0 M6,5 V15 M6,15 a2,2 0 1,0 0.01,0 M14,6 a2,2 0 1,0 0.01,0 M14,8 C14,12 6,11 6,13"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TitleBarVM.CurrentBranch}" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontFamilyMono}" Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    <Path Width="8" Height="5" Margin="6,0,0,0" Data="M0,0 L4,4 L8,0"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Popup Grid.Column="1" PlacementTarget="{Binding ElementName=BranchToggle}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=BranchToggle, Mode=TwoWay}">
                <Border Width="300" MaxHeight="360" Background="{StaticResource BackgroundPrimary}"
                        BorderBrush="{StaticResource BorderTertiary}" BorderThickness="1"
                        CornerRadius="8" Padding="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.22" Color="#000000"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BranchesVM.LocalBranches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                            Command="{Binding DataContext.BranchesVM.CheckoutNamedCommand, ElementName=Root}"
                                            CommandParameter="{Binding Name}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Text="✓" Foreground="{StaticResource AccentBlue}"
                                                       FontWeight="Bold" Width="14"
                                                       Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource FontFamilyMono}"
                                                       Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- ── A3: Fetch / Pull / Push(split) / Sync ─────────────────── -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ToolbarButton}" Content="Fetch" Command="{Binding FetchCommand}" ToolTip="Fetch (F5)"/>
                <Button Style="{StaticResource ToolbarButton}" Content="Pull" Command="{Binding PullCommand}"/>

                <!-- Push split button -->
                <Border BorderBrush="{StaticResource BorderSecondary}" BorderThickness="1" CornerRadius="8"
                        Margin="0,0,4,0" Height="28">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding PushCommand}" BorderThickness="0" Background="Transparent"
                                Padding="10,0" Cursor="Hand" VerticalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Push" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource AccentWarning}" CornerRadius="8" Padding="5,0" Margin="6,0,0,0"
                                        Visibility="{Binding TitleBarVM.HasOutgoing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding TitleBarVM.OutgoingCount}" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        <Rectangle Width="1" Fill="{StaticResource BorderTertiary}" Margin="0,4"/>
                        <ToggleButton x:Name="PushMore" Width="22" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Path Width="8" Height="5" Data="M0,0 L4,4 L8,0" Stroke="{StaticResource TextSecondary}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="Transparent"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>
                <Popup PlacementTarget="{Binding ElementName=PushMore}" Placement="Bottom" StaysOpen="False"
                       AllowsTransparency="True" IsOpen="{Binding IsChecked, ElementName=PushMore, Mode=TwoWay}">
                    <Border Background="{StaticResource BackgroundPrimary}" BorderBrush="{StaticResource BorderTertiary}"
                            BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="220">
                        <StackPanel>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushCommand}" Content="Push"/>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushForceWithLeaseCommand}"
                                    Content="Push (force-with-lease)"/>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushForceCommand}">
                                <TextBlock Text="Push (force)" Foreground="{StaticResource AccentDanger}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button Style="{StaticResource ToolbarButton}" Content="Sync" Command="{Binding SyncCommand}"
                        ToolTip="Fetch + Pull + Push"/>
            </StackPanel>

            <!-- ── Auto-fetch + ahead/behind ─────────────────────────────── -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="6,0,10,0">
                    <TextBlock Text="↓" VerticalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                    <TextBlock Text="{Binding TitleBarVM.IncomingCount}" Margin="2,0,8,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="↑" VerticalAlignment="Center" Foreground="{StaticResource TextTertiary}"/>
                    <TextBlock Text="{Binding TitleBarVM.OutgoingCount}" Margin="2,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <ToggleButton IsChecked="{Binding TitleBarVM.AutoFetchEnabled}" Width="28" Height="28"
                              Background="Transparent" BorderThickness="0" ToolTip="{Binding TitleBarVM.AutoFetchTooltip}">
                    <Grid>
                        <Path Stretch="Uniform" Width="14" Height="14" Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Data="M3,10 a7,7 0 0,1 14,0 M17,10 L14,7 M17,10 L20,7 M17,10 a7,7 0 0,1 -14,0 M3,10 L6,13 M3,10 L0,13"/>
                        <Ellipse Width="5" Height="5" Fill="{StaticResource AccentSuccess}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                 Visibility="{Binding TitleBarVM.AutoFetchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </ToggleButton>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
