<UserControl x:Class="Gitster.Controls.Toolbar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">
    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- "Current" marker: a bold green check inside a light-green checkbox, shown in the icon area. -->
        <Style x:Key="CurrentCheckMarker" TargetType="Control">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border CornerRadius="3"
                                Background="{DynamicResource AccentSuccessBackground}"
                                BorderBrush="{DynamicResource AccentSuccess}" BorderThickness="1">
                            <TextBlock Text="&#x2713;" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentSuccess}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RepoPinButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                Property="Background"
                                Value="{DynamicResource AccentBlueBackground}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd"
                                Property="Background"
                                Value="{DynamicResource RepoDropPressedBrush}"/>
                            </Trigger>

                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RepoPinIcon" TargetType="Path">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Data" Value="{StaticResource IconPinGeometry}"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                    <Setter Property="Fill" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DropItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{DynamicResource AccentBlueBackground}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{DynamicResource RepoDropPressedBrush}"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Remove-from-list (✕) marker, right-aligned. Hidden for pinned favorites. -->
        <Style x:Key="RepoRemoveButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Path x:Name="Glyph" Width="10" Height="10" Stretch="Uniform"
                                  Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M1,1 L9,9 M9,1 L1,9"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDangerBackground}"/>
                                <Setter TargetName="Glyph" Property="Stroke" Value="{DynamicResource AccentDanger}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource RepoDropPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Reveal on row hover; pinned favourites never show a remove marker. -->
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- A pinned/recent repo row: [pin] name + path (opens repo) [✕ remove] -->
        <DataTemplate x:Key="RepoDropItemTemplate">
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource RepoPinButton}"
                        Command="{Binding DataContext.TitleBarVM.TogglePinRepoCommand, ElementName=Root}"
                        CommandParameter="{Binding FullPath}"
                        AutomationProperties.Name="{Binding PinTooltip}"
                        ToolTip="{Binding PinTooltip}">
                    <Path Style="{StaticResource RepoPinIcon}"/>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource DropItemButton}" Click="ClosePopup"
                        Command="{Binding DataContext.OpenRepoCommand, ElementName=Root}"
                        CommandParameter="{Binding FullPath}" ToolTip="{Binding FullPath}" ToolTipService.Placement="Bottom">
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimary}"
                                   FontWeight="Medium" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding DisplayPath}" Foreground="{DynamicResource TextSecondary}" Opacity="0.6"
                                   FontFamily="{StaticResource FontFamilyMono}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource RepoRemoveButton}"
                        Command="{Binding DataContext.TitleBarVM.RemoveRecentRepoCommand, ElementName=Root}"
                        CommandParameter="{Binding FullPath}"
                        AutomationProperties.Name="Remove from list"
                        ToolTip="Remove from recent list"/>
            </Grid>
        </DataTemplate>

        <!-- ══ Branch picker (A11) ═══════════════════════════════════════════ -->

        <!-- Pin marker for a branch row: green = global favourite (locked), blue = local pin. -->
        <Style x:Key="BranchPinIcon" TargetType="Path">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="StrokeThickness" Value="1.4"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Data" Value="{StaticResource IconPinGeometry}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                    <Setter Property="Fill" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>
                <!-- Global favourite wins: locked green pin. -->
                <DataTrigger Binding="{Binding IsGlobalFavorite}" Value="True">
                    <Setter Property="Stroke" Value="{DynamicResource AccentSuccess}"/>
                    <Setter Property="Fill" Value="{DynamicResource AccentSuccess}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BranchPinButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Collapsible folder header in the branch tree. -->
        <Style x:Key="BranchFolderToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="0,4">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Recursive branch node: a "/"-folder (collapsible) or a leaf branch (pin + checkout). -->
        <DataTemplate x:Key="BranchNodeTemplate">
            <StackPanel>
                <!-- Folder -->
                <ToggleButton Style="{StaticResource BranchFolderToggle}"
                              IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                              Visibility="{Binding IsFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="Chevron" Grid.Column="0" Text="&#xE76C;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="8,0,0,0" VerticalAlignment="Center"
                                   FontWeight="Medium" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                                   FontFamily="{StaticResource FontFamilyMono}" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </ToggleButton>

                <!-- Branch leaf: [current check | name | pin] -->
                <Grid Background="Transparent"
                      Visibility="{Binding IsBranch, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Left icon area: only the green check for the checked-out branch -->
                    <Control Grid.Column="0" Style="{StaticResource CurrentCheckMarker}"
                             Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}"
                             ToolTip="Current branch"/>
                    <Button Grid.Column="1" Style="{StaticResource DropItemButton}" Click="ClosePopup"
                            Command="{Binding DataContext.BranchesVM.CheckoutNamedCommand, ElementName=Root}"
                            CommandParameter="{Binding FullName}" ToolTip="{Binding FullName}">
                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource FontFamilyMono}" FontSize="12"
                                   Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <!-- Right: pin toggle (green locked global favourite / blue removable local pin) -->
                    <Button Grid.Column="2" Style="{StaticResource BranchPinButton}"
                            Command="{Binding DataContext.BranchesVM.ToggleBranchPinCommand, ElementName=Root}"
                            CommandParameter="{Binding FullName}"
                            AutomationProperties.Name="{Binding PinTooltip}"
                            ToolTip="{Binding PinTooltip}">
                        <Path Style="{StaticResource BranchPinIcon}"/>
                    </Button>
                </Grid>

                <!-- Children (folders only; leaves have none) -->
                <ItemsControl Margin="14,0,0,0" ItemsSource="{Binding Children}"
                              ItemTemplate="{DynamicResource BranchNodeTemplate}"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter TargetName="Chevron" Property="Text" Value="&#xE70D;"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource BackgroundSecondary}"
            BorderBrush="{DynamicResource BorderTertiary}" BorderThickness="0,0,0,0.5"
            Padding="8,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ── A4: Switch-repo dropdown ──────────────────────────────── -->
            <ToggleButton x:Name="RepoToggle" Grid.Column="0" Height="28" Margin="0,0,6,0"
                          Background="Transparent" BorderBrush="{DynamicResource BorderSecondary}"
                          BorderThickness="1" Padding="8,2" Cursor="Hand"
                          AutomationProperties.Name="Switch repository">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding TitleBarVM.RepositoryName}" VerticalAlignment="Center"
                               FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    <Path Width="8" Height="5" Margin="6,0,0,0" Data="{StaticResource IconChevronDownGeometry}"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Popup Grid.Column="0" PlacementTarget="{Binding ElementName=RepoToggle}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=RepoToggle, Mode=TwoWay}">
                <Border Width="340" Background="{DynamicResource BackgroundPrimary}"
                        BorderBrush="{DynamicResource BorderTertiary}" BorderThickness="1"
                        CornerRadius="8" Padding="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.22" Color="{DynamicResource OverlayShadowColor}"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Current repo header — a static status banner, deliberately not styled
                             like the selectable rows (accent stripe + pill, no hover affordance). -->
                        <TextBlock Text="CURRENT REPOSITORY" FontSize="9" FontWeight="SemiBold" Margin="8,2,0,3"
                                   Foreground="{DynamicResource TextTertiary}"/>
                        <Border Background="{DynamicResource AccentSuccessBackground}" CornerRadius="6" Padding="0"
                                Margin="0,0,0,6" BorderBrush="{DynamicResource AccentSuccess}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- 28px checkmark column mirrors the pin column so the name lines up with the rows. -->
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x2713;" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentSuccess}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="8,7,8,7">
                                    <TextBlock Text="{Binding TitleBarVM.RepositoryName}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding TitleBarVM.CurrentRepositoryPath}" FontSize="10"
                                               FontFamily="{StaticResource FontFamilyMono}"
                                               Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Border Grid.Column="2" Background="{DynamicResource AccentSuccess}" CornerRadius="4"
                                        Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="CURRENT" FontSize="9" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Pinned -->
                        <TextBlock Text="PINNED" FontSize="9" FontWeight="SemiBold" Margin="8,4,0,3"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TitleBarVM.PinnedItems}"
                                      ItemTemplate="{StaticResource RepoDropItemTemplate}"
                                      Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Separator Margin="4,4"
                                   Visibility="{Binding TitleBarVM.HasPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- Recent -->
                        <TextBlock Text="RECENT" FontSize="9" FontWeight="SemiBold" Margin="8,2,0,3"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Visibility="{Binding TitleBarVM.HasRecentOnly, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding TitleBarVM.RecentItems}"
                                      ItemTemplate="{StaticResource RepoDropItemTemplate}"
                                      Visibility="{Binding TitleBarVM.HasRecentOnly, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Separator Margin="4,4"/>
                        <Button Style="{StaticResource DropItemButton}" Click="ClosePopup" HorizontalContentAlignment="Stretch"
                                Padding="0,4" Command="{Binding BrowseFolderCommand}">
                            <!-- Columns mirror the repo rows so the label lines up with the item names. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📁" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Browse repository…" Margin="8,0,0,0"
                                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Grid.Column="2" Text="Ctrl+O" Margin="0,0,8,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiary}" FontSize="11"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ── A11: Branch dropdown ──────────────────────────────────── -->
            <ToggleButton x:Name="BranchToggle" Grid.Column="1" Height="28" Margin="0,0,12,0"
                          Background="Transparent" BorderBrush="{DynamicResource BorderSecondary}"
                          BorderThickness="1" Padding="8,2" Cursor="Hand"
                          AutomationProperties.Name="Switch branch">
                <StackPanel Orientation="Horizontal">
                    <Path Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" Fill="Transparent"
                          Data="M6,3 a2,2 0 1,0 0.01,0 M6,5 V15 M6,15 a2,2 0 1,0 0.01,0 M14,6 a2,2 0 1,0 0.01,0 M14,8 C14,12 6,11 6,13"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TitleBarVM.CurrentBranch}" VerticalAlignment="Center"
                               FontFamily="{StaticResource FontFamilyMono}" Foreground="{DynamicResource TextPrimary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    <Path Width="8" Height="5" Margin="6,0,0,0" Data="{StaticResource IconChevronDownGeometry}"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Fill="Transparent" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Popup Grid.Column="1" PlacementTarget="{Binding ElementName=BranchToggle}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=BranchToggle, Mode=TwoWay}">
                <Border Width="320" Background="{DynamicResource BackgroundPrimary}"
                        BorderBrush="{DynamicResource BorderTertiary}" BorderThickness="1"
                        CornerRadius="8" Padding="6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.22" Color="{DynamicResource OverlayShadowColor}"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Favourites -->
                        <TextBlock Text="FAVOURITES" FontSize="9" FontWeight="SemiBold" Margin="8,4,0,3"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Visibility="{Binding BranchesVM.HasFavoriteBranches, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <ItemsControl ItemsSource="{Binding BranchesVM.FavoriteBranches}"
                                      ItemTemplate="{StaticResource BranchNodeTemplate}"
                                      Visibility="{Binding BranchesVM.HasFavoriteBranches, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Separator Margin="4,4"
                                   Visibility="{Binding BranchesVM.HasFavoriteBranches, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <!-- All branches, "/"-folder tree -->
                        <TextBlock Text="BRANCHES" FontSize="9" FontWeight="SemiBold" Margin="8,2,0,3"
                                   Foreground="{DynamicResource TextTertiary}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding BranchesVM.BranchPickerTree}"
                                          ItemTemplate="{StaticResource BranchNodeTemplate}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ── A3: Fetch / Pull / Push(split) / Sync ─────────────────── -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ToolbarButton}" Content="Fetch" Command="{Binding FetchCommand}" ToolTip="Fetch (F5)"
                        AutomationProperties.Name="Fetch from remote"/>
                <Button Style="{StaticResource ToolbarButton}" Content="Pull" Command="{Binding PullCommand}"
                        AutomationProperties.Name="Pull from remote"/>

                <!-- Push split button -->
                <Border BorderBrush="{DynamicResource BorderSecondary}" BorderThickness="1" CornerRadius="8"
                        Margin="0,0,4,0" Height="28">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding PushCommand}" BorderThickness="0" Background="Transparent"
                                Padding="10,0" Cursor="Hand" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Push to remote">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Push" VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource AccentWarning}" CornerRadius="8" Height="8" Width="8" Padding="0" Margin="6,2,0,0"
                                        Visibility="{Binding TitleBarVM.HasOutgoing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding TitleBarVM.OutgoingCount}" Foreground="White" FontSize="10" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Button>
                        <Rectangle Width="1" Fill="{DynamicResource BorderTertiary}" Margin="0,4"/>
                        <ToggleButton x:Name="PushMore" Width="22" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                      AutomationProperties.Name="More push options"
                                      ToolTip="More push options">
                            <Path Width="8" Height="5" Data="{StaticResource IconChevronDownGeometry}" Stroke="{DynamicResource TextSecondary}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="Transparent"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>
                <Popup PlacementTarget="{Binding ElementName=PushMore}" Placement="Bottom" StaysOpen="False"
                       AllowsTransparency="True" IsOpen="{Binding IsChecked, ElementName=PushMore, Mode=TwoWay}">
                    <Border Background="{DynamicResource BackgroundPrimary}" BorderBrush="{DynamicResource BorderTertiary}"
                            BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="220">
                        <StackPanel>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushCommand}" Content="Push"/>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushForceWithLeaseCommand}"
                                    Content="Push (force-with-lease)"/>
                            <Button Style="{StaticResource DropItemButton}" Click="ClosePopup"
                                    Command="{Binding PushForceCommand}">
                                <TextBlock Text="Push (force)" Foreground="{DynamicResource AccentDanger}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button Style="{StaticResource ToolbarButton}" Content="Sync" Command="{Binding SyncCommand}"
                        ToolTip="Fetch + Pull + Push"
                        AutomationProperties.Name="Sync with remote"/>
            </StackPanel>

            <!-- ── Auto-fetch + ahead/behind ─────────────────────────────── -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="6,0,10,0">
                    <TextBlock Text="↓" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                    <TextBlock Text="{Binding TitleBarVM.IncomingCount}" Margin="2,0,8,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock Text="↑" VerticalAlignment="Center" Foreground="{DynamicResource TextTertiary}"/>
                    <TextBlock Text="{Binding TitleBarVM.OutgoingCount}" Margin="2,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                <ToggleButton IsChecked="{Binding TitleBarVM.AutoFetchEnabled}" Width="28" Height="28"
                              Background="Transparent" BorderThickness="0" ToolTip="{Binding TitleBarVM.AutoFetchTooltip}"
                              AutomationProperties.Name="Auto-fetch">
                    <Grid>
                        <Path Stretch="Uniform" Width="14" Height="14" Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Data="{StaticResource IconSyncGeometry}"/>
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentSuccess}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,0"
                                 Visibility="{Binding TitleBarVM.AutoFetchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </ToggleButton>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
