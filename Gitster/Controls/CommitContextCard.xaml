<UserControl x:Class="Gitster.Controls.CommitContextCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Path Width="12" Height="12" Stretch="Uniform"
                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M10,10 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0 M10,10 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Selected Commit"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message (or placeholder when nothing is selected) -->
            <TextBlock TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding SelectedCommit.Message}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text"       Value="{Binding SelectedCommit.Message}"/>
                        <Setter Property="FontWeight"  Value="Medium"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                <Setter Property="Text"       Value="No commit selected"/>
                                <Setter Property="Foreground"  Value="{StaticResource TextTertiary}"/>
                                <Setter Property="FontStyle"   Value="Italic"/>
                                <Setter Property="FontWeight"  Value="Normal"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- SHA · date (hidden when nothing is selected) -->
            <TextBlock Margin="0,5,0,0"
                       FontFamily="{StaticResource FontFamilyMono}"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="{Binding SelectedCommit.CommitId, Mode=OneWay}"/>
                <Run Text=" · "/>
                <Run Text="{Binding SelectedCommit.Date, StringFormat='dd.MM.yyyy HH:mm', Mode=OneWay}"/>
            </TextBlock>

        </StackPanel>
    </Border>
</UserControl>
