<UserControl x:Class="Gitster.Controls.CommitContextCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:local="clr-namespace:Gitster.Controls"
             xmlns:converters="clr-namespace:Gitster.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <UserControl.Resources>
        <converters:DateDisplayConverter x:Key="CardDateConverter"/>
        <!-- Shared copy glyph used by both copy buttons -->
        <Geometry x:Key="CopyGlyph">M7,3 H17 V17 H7 Z M3,7 H7 M3,7 V17 H7</Geometry>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Message + borderless copy button -->
            <Grid Margin="0,0,0,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="39"
                           ToolTip="{Binding SelectedCommit.DisplayMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"      Value="{Binding SelectedCommit.DisplayMessage}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize"   Value="14"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedCommit}" Value="{x:Null}">
                                    <Setter Property="Text"       Value="No commit selected"/>
                                    <Setter Property="Foreground"  Value="{DynamicResource TextTertiary}"/>
                                    <Setter Property="FontStyle"   Value="Italic"/>
                                    <Setter Property="FontWeight"  Value="Normal"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="1" Style="{StaticResource CopyGlyphButton}"
                        VerticalAlignment="Top"
                        ToolTip="Copy message"
                        AutomationProperties.Name="Copy commit message"
                        Tag="{Binding SelectedCommit.DisplayMessage}" Click="CopyMessage_Click"
                        Visibility="{Binding SelectedCommit, Converter={StaticResource NullToCollapsedConverter}}">
                    <Path Width="11" Height="11" Stretch="Uniform" Fill="Transparent"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" Data="{StaticResource CopyGlyph}"/>
                </Button>
            </Grid>

            <!-- Details (hidden when nothing is selected) -->
            <StackPanel Visibility="{Binding SelectedCommit, Converter={StaticResource NullToCollapsedConverter}}">

                <!-- Author -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <local:Avatar Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"
                                  Email="{Binding SelectedCommit.DisplayAuthorEmail}"
                                  DisplayName="{Binding SelectedCommit.DisplayAuthorName}"
                                  Enabled="{Binding Ui.GravatarEnabled}"/>
                    <TextBlock Text="{Binding SelectedCommit.DisplayAuthorName}" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- SHA (expands to full on hover) + remote dot + copy -->
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource AccentWarning}"/>
                                <Setter Property="ToolTip" Value="Outgoing — local only"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCommit.RemoteState}" Value="Incoming">
                                        <Setter Property="Fill" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="ToolTip" Value="Incoming — on remote, not yet merged locally"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCommit.RemoteState}" Value="OnRemote">
                                        <Setter Property="Fill" Value="Transparent"/>
                                        <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                        <Setter Property="ToolTip" Value="Synced — on both local and remote"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedCommit.RemoteState}" Value="NoTrackingBranch">
                                        <Setter Property="Fill" Value="{DynamicResource AccentWarning}"/>
                                        <Setter Property="ToolTip" Value="No tracking branch — local only"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Abbreviated by default; the value itself expands to the full 40-char SHA on hover -->
                    <TextBlock Grid.Column="1" x:Name="ShaText"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11"
                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" ToolTip="Hover to reveal full SHA">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding SelectedCommit.CommitId}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Text" Value="{Binding SelectedCommit.FullSha}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Grid.Column="2" Style="{StaticResource CopyGlyphButton}"
                            ToolTip="Copy full SHA"
                            AutomationProperties.Name="Copy full SHA"
                            Tag="{Binding SelectedCommit.FullSha}" Click="CopySha_Click">
                        <Path Width="11" Height="11" Stretch="Uniform" Fill="Transparent"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" Data="{StaticResource CopyGlyph}"/>
                    </Button>
                </Grid>

                <!-- Date on its own line (absolute by default, A10) -->
                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource CardDateConverter}">
                            <Binding Path="SelectedCommit.DisplayDate"/>
                            <Binding Path="Ui.UseRelativeDates"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
