<UserControl x:Class="Gitster.Controls.TimestampEditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TimestampEditViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="⏱" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="New Timestamp"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Date (2/3) + Time (1/3) inputs -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:DateControl Grid.Column="0"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                      EditMode="DateOnly"
                                      Height="30"/>
                <controls:DateControl Grid.Column="2"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                      EditMode="TimeOnly"
                                      Height="30"/>
            </Grid>

            <!-- Restore the "read timestamp from commit" affordance (plan: deferred section) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="⤓ From selected commit"
                        Command="{Binding ReadFromSelectedCommitCommand}"
                        Style="{StaticResource GhostButton}" Padding="8,3" FontSize="11"
                        ToolTip="Load the selected commit's time into the editor"/>
                <Button Content="⤓ From HEAD"
                        Command="{Binding ReadFromCurrentCommitCommand}"
                        Style="{StaticResource GhostButton}" Padding="8,3" FontSize="11" Margin="4,0,0,0"
                        ToolTip="Load HEAD's time into the editor"/>
            </StackPanel>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Presets}"
                          DisplayMemberPath="Label"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"/>
                <Button Grid.Column="2"
                        Content="Apply preset"
                        Command="{Binding ApplySelectedPresetCommand}"
                        Style="{StaticResource GhostButton}"
                        Padding="8,3"/>
            </Grid>

            <!-- Preset buttons -->
            <ItemsControl ItemsSource="{Binding Presets}" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}"
                                Command="{Binding DataContext.ApplyPresetCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource GhostButton}"
                                Padding="8,4"
                                Margin="0,0,4,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Before / After preview — timestamp row always shown; author row shown when author changes -->
            <Border Background="{DynamicResource BackgroundSecondary}"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Padding="8,6"
                    Margin="0,0,0,10">
                <StackPanel>

                    <!-- Timestamp row -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="timestamp"
                                   Foreground="{DynamicResource TextTertiary}"
                                   FontSize="10"/>
                        <TextBlock Grid.Column="1"
                                   FontFamily="{StaticResource FontFamilyMono}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Text="{Binding PreviewBefore}"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="→ new"
                                   Foreground="{DynamicResource AccentWarning}"
                                   FontSize="10"/>
                        <TextBlock Grid.Column="1"
                                   FontFamily="{StaticResource FontFamilyMono}"
                                   FontSize="11">
                            <Run Text="{Binding PreviewAfter, Mode=OneWay}" Foreground="{DynamicResource TextPrimary}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Author/committer row (only shown when there is a pending change) -->
                    <Grid Margin="0,0,0,0"
                          Visibility="{Binding DataContext.AuthorPanelVM.IsApplyEnabled,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="→ author"
                                   Foreground="{DynamicResource AccentWarning}"
                                   FontSize="10"/>
                        <TextBlock Grid.Column="1"
                                   FontFamily="{StaticResource FontFamilyMono}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Text="{Binding DataContext.AuthorPanelVM.AuthorText,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Safety warning (shown when selected commit is already on remote) -->
            <Border Visibility="{Binding DataContext.IsAmendUnsafe,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{DynamicResource AccentWarningBackground}"
                    BorderBrush="{DynamicResource AccentWarning}"
                    BorderThickness="0.5"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Padding="10,7"
                    Margin="0,0,0,8">
                <TextBlock TextWrapping="Wrap" FontSize="11">
                    <Run Text="⚠" Foreground="{DynamicResource AccentWarning}"/>
                    <Run Text=" This commit is already on the remote. Amending it will require a force-push."
                         Foreground="{DynamicResource TextPrimary}"/>
                </TextBlock>
            </Border>

            <!-- Amend button — command lives on the Window's MainWindowViewModel -->
            <Button Command="{Binding DataContext.AmendCommitCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    IsEnabled="{Binding DataContext.CanAmendSelectedCommit,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                    HorizontalAlignment="Stretch"
                    Height="36">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Content" Value="✏  Amend selected commit"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsAmendUnsafe,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="True">
                                <Setter Property="Content" Value="✏  Amend selected (force-push required)"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</UserControl>
