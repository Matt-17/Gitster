<UserControl x:Class="Gitster.Controls.TimestampEditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TimestampEditViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="⏱" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="New Timestamp"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Date (2/3) + Time (1/3) inputs -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:DateControl Grid.Column="0"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                      EditMode="DateOnly"
                                      Height="30"/>
                <controls:DateControl Grid.Column="2"
                                      SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                      EditMode="TimeOnly"
                                      Height="30"/>
            </Grid>

            <!-- Preset buttons -->
            <ItemsControl ItemsSource="{Binding Presets}" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}"
                                Command="{Binding DataContext.ApplyPresetCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource GhostButton}"
                                Padding="8,4"
                                Margin="0,0,4,4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Before / After preview -->
            <Border Background="{StaticResource BackgroundSecondary}"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Padding="8,6"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="before"
                               Foreground="{StaticResource TextTertiary}"
                               FontSize="11"
                               Margin="0,0,10,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding PreviewBefore}"
                               FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="11"
                               Foreground="{StaticResource TextPrimary}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="after"
                               Foreground="{StaticResource TextTertiary}"
                               FontSize="11"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="11">
                        <Run Text="{Binding PreviewAfter, Mode=OneWay}"/>
                        <Run Text=" · → new" Foreground="{StaticResource AccentWarning}"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Amend button — command lives on the Window's MainWindowViewModel -->
            <Button Content="✏  Amend"
                    Command="{Binding DataContext.AmendCommitCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    IsEnabled="{Binding DataContext.IsGoButtonEnabled,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Stretch"
                    Height="36"/>

        </StackPanel>
    </Border>
</UserControl>
