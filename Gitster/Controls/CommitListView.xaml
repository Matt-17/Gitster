<UserControl x:Class="Gitster.Controls.CommitListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:converters="clr-namespace:Gitster.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <UserControl.Resources>
        <converters:DateDisplayConverter x:Key="DateCellConverter"/>
        <converters:DateDisplayConverter x:Key="DateTooltipConverter" Invert="True"/>

        <!-- Commit-row container: hover + selection visuals, uniform height for virtualization -->
        <Style x:Key="CommitItemStyle" TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section-header container: display-only, never selectable or focusable -->
        <Style x:Key="SectionHeaderItemStyle" TargetType="ListViewItem">
            <Setter Property="Focusable"        Value="False"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header row (A5): Remote (incoming) blue / Local (outgoing) amber -->
        <DataTemplate x:Key="SectionHeaderTemplate">
            <Border Padding="8,4" BorderThickness="0,0,0,0.5"
                    BorderBrush="{StaticResource BorderTertiary}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource AccentInfoBackground}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentWarningBackground}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="↓"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                        <Setter Property="Text" Value="↑"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="11"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding RemoteLabel}" FontSize="11" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="{Binding RemoteUrlDisplay}" FontSize="10" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource FontFamilyMono}"
                               Foreground="{StaticResource TextTertiary}"
                               TextTrimming="CharacterEllipsis" MaxWidth="220"
                               Visibility="{Binding HasRemoteUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Hint}" FontSize="11" Margin="6,0,0,0"
                               VerticalAlignment="Center" FontStyle="Italic"
                               Foreground="{StaticResource TextTertiary}"
                               Visibility="{Binding ShowHint, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Commit row (A1 ordering, A0 uniform 24px height) -->
        <DataTemplate x:Key="CommitRowTemplate">
            <Grid Height="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="62"/>
                </Grid.ColumnDefinitions>

                <!-- Graph spine + remote-state dot + orphan indicator -->
                <Grid Grid.Column="0">
                    <Rectangle Width="1.5" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Fill" Value="{StaticResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="LocalOnly">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="NoTrackingBranch">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="Incoming">
                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>
                    <TextBlock Text="↔" FontSize="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,1,0,0" Foreground="{StaticResource AccentWarning}"
                               ToolTip="Same commit, rewritten. Push (force-with-lease) to replace the remote copy."
                               Visibility="{Binding IsOrphanedPair, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Ellipse Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="Incoming">
                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="LocalOnly">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="NoTrackingBranch">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RemoteState}" Value="OnRemote">
                                        <Setter Property="Fill" Value="{StaticResource BackgroundPrimary}"/>
                                        <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>

                <TextBlock Grid.Column="1" Text="{Binding Message}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Margin="2,0,8,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <local:Avatar Email="{Binding AuthorEmail}" DisplayName="{Binding AuthorName}"
                                  Margin="0,0,5,0"
                                  Enabled="{Binding DataContext.Ui.GravatarEnabled, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                    <TextBlock Text="{Binding AuthorName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}" FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource DateCellConverter}">
                            <Binding Path="Date"/>
                            <Binding Path="DataContext.Ui.UseRelativeDates"
                                     RelativeSource="{RelativeSource AncestorType=ListView}"/>
                        </MultiBinding>
                    </TextBlock.Text>
                    <TextBlock.ToolTip>
                        <MultiBinding Converter="{StaticResource DateTooltipConverter}">
                            <Binding Path="Date"/>
                            <Binding Path="DataContext.Ui.UseRelativeDates"
                                     RelativeSource="{RelativeSource AncestorType=ListView}"/>
                        </MultiBinding>
                    </TextBlock.ToolTip>
                </TextBlock>
                <TextBlock Grid.Column="4" Text="{Binding CommitId}" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontFamilyMono}" FontSize="11"
                           Foreground="{StaticResource TextSecondary}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="160" MinHeight="60"/>
        </Grid.RowDefinitions>

        <!-- ── Filter row ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="0,0,0,1"
                Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <local:SearchBox Grid.Column="0"
                                 x:Name="SearchBoxControl"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Placeholder="Search  (author:Name  message:&quot;fix bug&quot;  sha:abc  after:2026-01-01)"/>

                <Button Grid.Column="1"
                        Width="28" Height="28" Margin="4,0,0,0"
                        Command="{Binding ClearAllFiltersCommand}"
                        ToolTip="Reset filter"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Style="{StaticResource GhostButton}">
                    <Path Stretch="Uniform" Width="12" Height="12"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                          Fill="Transparent"
                          Data="M4,4 L16,16 M16,4 L4,16"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Commit list (virtualized flat heterogeneous list) ───────── -->
        <ListView x:Name="CommitListBox"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedCommit, Mode=TwoWay}"
                  SelectionMode="Extended"
                  SelectionChanged="CommitListBox_SelectionChanged"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Item"
                  ScrollViewer.IsDeferredScrollingEnabled="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                Color="#007ACC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"            Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#CCE4F7"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1F1F1F"/>
            </ListView.Resources>

            <ListView.ItemContainerStyleSelector>
                <local:CommitContainerStyleSelector
                    CommitStyle="{StaticResource CommitItemStyle}"
                    HeaderStyle="{StaticResource SectionHeaderItemStyle}"/>
            </ListView.ItemContainerStyleSelector>

            <ListView.ItemTemplateSelector>
                <local:CommitRowTemplateSelector
                    CommitTemplate="{StaticResource CommitRowTemplate}"
                    HeaderTemplate="{StaticResource SectionHeaderTemplate}"/>
            </ListView.ItemTemplateSelector>
        </ListView>

        <!-- ── Horizontal splitter ─────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderTertiary}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ── Diff preview (consolidated DiffView, B7) ────────────────── -->
        <local:DiffView Grid.Row="3" Header="{Binding DiffHeaderDisplay}" Files="{Binding DiffFiles}"/>
    </Grid>
</UserControl>
