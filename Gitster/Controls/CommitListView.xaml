<UserControl x:Class="Gitster.Controls.CommitListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:converters="clr-namespace:Gitster.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:RelativeDateConverter x:Key="RelativeDateConverter" Mode="Relative"/>
        <converters:RelativeDateConverter x:Key="FullDateConverter"     Mode="Full"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="160" MinHeight="60"/>
        </Grid.RowDefinitions>

        <!-- ── Filter row ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="0,0,0,1"
                Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundPrimary}"
                        BorderBrush="{StaticResource BorderTertiary}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusMd}"
                        Padding="6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="🔍"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="{StaticResource TextTertiary}"/>

                        <!-- Placeholder overlay -->
                        <TextBlock Grid.Column="1"
                                   Text="Search  (author:Name  ·  free text)"
                                   Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Grid.Column="1"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" Height="26"
                                 Foreground="{StaticResource TextPrimary}"/>
                    </Grid>
                </Border>

                <!-- Clear-filter button (visible only when filters are active) -->
                <Button Grid.Column="1"
                        Content="🗑️" Width="28" Height="28" Margin="4,0,0,0"
                        Command="{Binding ClearAllFiltersCommand}"
                        ToolTip="Reset filters"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource IconButton}"/>

                <!-- Advanced filter dialog button -->
                <Button Grid.Column="2"
                        Content="⚙" Width="28" Height="28" Margin="4,0,0,0"
                        Command="{Binding OpenFilterCommand}"
                        ToolTip="Advanced filter"
                        Style="{StaticResource IconButton}"/>
            </Grid>
        </Border>

        <!-- ── Commit list ─────────────────────────────────────────────── -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Commits}"
                  SelectedItem="{Binding SelectedCommit, Mode=TwoWay}">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                    <Setter Property="Padding"     Value="4,2"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <GridViewRowPresenter
                                        Columns="{TemplateBinding GridView.ColumnCollection}"
                                        Content="{TemplateBinding Content}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{StaticResource BackgroundSecondary}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{StaticResource AccentBlueBackground}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected"  Value="True"/>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.Setters>
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource AccentBlueBackground}"/>
                                        </MultiTrigger.Setters>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Message" Width="170"
                                    DisplayMemberBinding="{Binding Message}"/>
                    <GridViewColumn Header="Author"  Width="100"
                                    DisplayMemberBinding="{Binding AuthorName}"/>
                    <GridViewColumn Header="Date"    Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Date, Converter={StaticResource RelativeDateConverter}}"
                                           ToolTip="{Binding Date, Converter={StaticResource FullDateConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="SHA"     Width="70"
                                    DisplayMemberBinding="{Binding CommitId}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Horizontal splitter ─────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderTertiary}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ── Diff preview ────────────────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1"
                    Padding="8,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄 " VerticalAlignment="Center"/>
                    <TextBlock Text="Diff"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DiffHeaderDisplay}"
                               FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="11"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiffHeader}" Value="">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- File list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DiffFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="8,3">
                                <TextBlock DockPanel.Dock="Right"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Margin="12,0,0,0">
                                    <Run Text="+" Foreground="{StaticResource AccentSuccess}"/><Run Text="{Binding Added, Mode=OneWay}" Foreground="{StaticResource AccentSuccess}"/><Run Text="  −" Foreground="{StaticResource AccentDanger}"/><Run Text="{Binding Deleted, Mode=OneWay}" Foreground="{StaticResource AccentDanger}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Path}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
