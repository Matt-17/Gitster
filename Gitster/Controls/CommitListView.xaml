<UserControl x:Class="Gitster.Controls.CommitListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:git="clr-namespace:Gitster.Services.Git"
             xmlns:converters="clr-namespace:Gitster.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <UserControl.Resources>
        <converters:RelativeDateConverter x:Key="RelativeDateConverter" Mode="Relative"/>
        <converters:RelativeDateConverter x:Key="FullDateConverter"     Mode="Full"/>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
        </Style>

        <!-- Commit-row container style (used by CommitListItemStyleSelector for real commits) -->
        <Style x:Key="CommitItemStyle" TargetType="ListViewItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"     Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter
                                Columns="{TemplateBinding GridView.ColumnCollection}"
                                Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource BackgroundSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{StaticResource AccentBlue}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="160" MinHeight="60"/>
        </Grid.RowDefinitions>

        <!-- ── Filter row ──────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource BorderTertiary}"
                BorderThickness="0,0,0,1"
                Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0"
                        Background="{StaticResource BackgroundPrimary}"
                        BorderBrush="{StaticResource BorderTertiary}"
                        BorderThickness="0.5"
                        CornerRadius="{StaticResource CornerRadiusMd}"
                        Padding="6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Path Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                              Stroke="{StaticResource TextTertiary}" StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M9,9 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 M13.5,13.5 L18,18"
                              VerticalAlignment="Center" Margin="0,0,4,0"/>

                        <!-- Placeholder overlay -->
                        <TextBlock Grid.Column="1"
                                   Text="Search  (author:Name  ·  free text)"
                                   Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" Height="26"
                                 Foreground="{StaticResource TextPrimary}"/>
                    </Grid>
                </Border>

                <!-- Clear-filter button (visible only when filters are active) -->
                <Button Grid.Column="1"
                        Width="28" Height="28" Margin="4,0,0,0"
                        Command="{Binding ClearAllFiltersCommand}"
                        ToolTip="Reset filters"
                        Visibility="{Binding HasActiveFilters, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Style="{StaticResource GhostButton}">
                    <Path Stretch="Uniform" Width="12" Height="12"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                          Fill="Transparent"
                          Data="M4,4 L16,16 M16,4 L4,16"/>
                </Button>

                <!-- Advanced filter dialog button -->
                <Button Grid.Column="2"
                        Width="28" Height="28" Margin="4,0,0,0"
                        Command="{Binding OpenFilterCommand}"
                        ToolTip="Advanced filter"
                        Style="{StaticResource GhostButton}">
                    <Path Stretch="Uniform" Width="12" Height="12"
                          Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                          Fill="Transparent"
                          Data="M2,4 L18,4 M5,10 L15,10 M8,16 L12,16"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Commit list ─────────────────────────────────────────────── -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding GroupedCommits}"
                  SelectedItem="{Binding SelectedCommit, Mode=TwoWay}">

            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <StackPanel>
                                            <Border BorderBrush="{StaticResource BorderTertiary}"
                                                    BorderThickness="0,0,0,0.5"
                                                    Padding="8,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Name}" Value="Incoming">
                                                                <Setter Property="Background" Value="{StaticResource AccentInfoBackground}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Name}" Value="Outgoing">
                                                                <Setter Property="Background" Value="{StaticResource AccentWarningBackground}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Section icon -->
                                                    <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✓"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Incoming">
                                                                        <Setter Property="Text" Value="↓"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Outgoing">
                                                                        <Setter Property="Text" Value="↑"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Section label with per-section color -->
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Medium" FontSize="11"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Incoming">
                                                                        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Outgoing">
                                                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Count text – reads real counts from the ViewModel (not ItemCount,
                                                         which includes the invisible placeholder sentinel).
                                                         Shows "· unknown" for Incoming when no tracking branch. -->
                                                    <TextBlock FontSize="11"
                                                               Foreground="{StaticResource TextTertiary}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0,0,0"
                                                               ToolTip="{Binding DataContext.IncomingNoTrackingTooltip, RelativeSource={RelativeSource AncestorType=ListView}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <!-- Default = Synced -->
                                                                <Setter Property="Text" Value="{Binding DataContext.SyncedCountText, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Incoming">
                                                                        <Setter Property="Text" Value="{Binding DataContext.IncomingCountText, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Name}" Value="Outgoing">
                                                                        <Setter Property="Text" Value="{Binding DataContext.OutgoingCountText, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <ItemsPresenter/>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListView.GroupStyle>

            <ListView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                Color="#007ACC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"            Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#CCE4F7"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1F1F1F"/>
            </ListView.Resources>

            <ListView.ItemContainerStyleSelector>
                <!-- Placeholder sentinels → Collapsed (invisible, 0 height).
                     Real commits        → CommitItemStyle with full hover/select visuals. -->
                <local:CommitListItemStyleSelector CommitStyle="{StaticResource CommitItemStyle}"/>
            </ListView.ItemContainerStyleSelector>

            <ListView.View>
                <GridView>
                    <!-- Branch graph spine + remote state indicator -->
                    <GridViewColumn Width="30">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Width="30">
                                    <!-- Spine line -->
                                    <Rectangle Width="1.5"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Stretch">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Fill" Value="{StaticResource TextTertiary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="LocalOnly">
                                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="NoTrackingBranch">
                                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="Incoming">
                                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                    <!-- Orphaned-pair indicator: ↔ shown when this commit was rewritten and its pair is visible -->
                                    <TextBlock Text="↔" FontSize="8"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               Margin="0,2,0,0"
                                               Foreground="{StaticResource AccentWarning}"
                                               ToolTip="Same commit, rewritten. Push (force-with-lease) to replace the remote copy.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOrphanedPair}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Circle indicator (remote state dot) -->
                                    <Ellipse Width="8" Height="8"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill"            Value="{StaticResource TextTertiary}"/>
                                                <Setter Property="Stroke"          Value="Transparent"/>
                                                <Setter Property="StrokeThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <!-- Incoming: filled blue dot -->
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="Incoming">
                                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                                    </DataTrigger>
                                                    <!-- Outgoing: filled amber dot -->
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="LocalOnly">
                                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="NoTrackingBranch">
                                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                                    </DataTrigger>
                                                    <!-- Synced: outlined ring -->
                                                    <DataTrigger Binding="{Binding RemoteState}" Value="OnRemote">
                                                        <Setter Property="Fill"            Value="{StaticResource BackgroundPrimary}"/>
                                                        <Setter Property="Stroke"          Value="{StaticResource TextTertiary}"/>
                                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Message" Width="170"
                                    DisplayMemberBinding="{Binding Message}"/>
                    <GridViewColumn Header="Author"  Width="100"
                                    DisplayMemberBinding="{Binding AuthorName}"/>
                    <GridViewColumn Header="Date"    Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Date, Converter={StaticResource RelativeDateConverter}}"
                                           ToolTip="{Binding Date, Converter={StaticResource FullDateConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="SHA" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CommitId}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Horizontal splitter ─────────────────────────────────────── -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderTertiary}"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- ── Diff preview ────────────────────────────────────────────── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundSecondary}"
                    BorderBrush="{StaticResource BorderTertiary}"
                    BorderThickness="0,0,0,1"
                    Padding="8,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📄 " VerticalAlignment="Center"/>
                    <TextBlock Text="Diff"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DiffHeaderDisplay}"
                               FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="11"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiffHeader}" Value="">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Remote-state indicator for selected commit (redundant safety indicator per spec) -->
                    <Ellipse Width="7" Height="7"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Transparent"/>
                                <Setter Property="Stroke" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiffRemoteState}" Value="Incoming">
                                        <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                        <Setter Property="ToolTip" Value="Incoming — on remote, not yet merged locally"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DiffRemoteState}" Value="LocalOnly">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                        <Setter Property="ToolTip" Value="Outgoing — local only, not yet pushed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DiffRemoteState}" Value="NoTrackingBranch">
                                        <Setter Property="Fill" Value="{StaticResource AccentWarning}"/>
                                        <Setter Property="ToolTip" Value="Outgoing — no tracking branch configured"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DiffRemoteState}" Value="OnRemote">
                                        <Setter Property="Fill" Value="Transparent"/>
                                        <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                        <Setter Property="ToolTip" Value="Synced — on both local and remote"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </Border>

            <!-- File list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DiffFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="8,3">
                                <TextBlock DockPanel.Dock="Right"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Margin="12,0,0,0">
                                    <Run Text="+" Foreground="{StaticResource AccentSuccess}"/><Run Text="{Binding Added, Mode=OneWay}" Foreground="{StaticResource AccentSuccess}"/><Run Text="  −" Foreground="{StaticResource AccentDanger}"/><Run Text="{Binding Deleted, Mode=OneWay}" Foreground="{StaticResource AccentDanger}"/>
                                </TextBlock>
                                <!-- Status badge: A/M/D/R -->
                                <Border DockPanel.Dock="Left"
                                        Margin="0,0,5,0"
                                        Width="14" Height="14"
                                        CornerRadius="2"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueBackground}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="A">
                                                    <Setter Property="Background" Value="{StaticResource AccentSuccessBackground}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="D">
                                                    <Setter Property="Background" Value="{StaticResource AccentDangerBackground}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="{StaticResource FontFamilyMono}"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="A">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentSuccess}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="D">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentDanger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{Binding Path}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
