<UserControl x:Class="Gitster.Controls.UndoBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:UndoBarViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border Background="{StaticResource AccentBlueBackground}"
            Padding="10,0"
            Height="36"
            Visibility="{Binding HasUndoableOperation, Converter={StaticResource BoolToVis}}">
        <DockPanel VerticalAlignment="Center">

            <!-- Right: action buttons -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Undo"
                        Command="{Binding UndoCommand}"
                        Style="{StaticResource GhostButton}"
                        Height="26"
                        Padding="10,2"
                        Margin="0,0,4,0"/>
                <Button Content="Log"
                        Command="{Binding OpenLogCommand}"
                        Style="{StaticResource GhostButton}"
                        Height="26"
                        Padding="10,2"/>
            </StackPanel>

            <!-- Left: description text -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🕘 " FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LastOperationText}"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </DockPanel>
    </Border>
</UserControl>
