<UserControl x:Class="Gitster.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             mc:Ignorable="d"
             Height="28">
    <UserControl.Resources>
        <Style x:Key="SearchInputTextBox" TargetType="TextBox" BasedOn="{StaticResource GitsterTextBox}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundPrimary}"
            BorderBrush="{StaticResource BorderTertiary}"
            BorderThickness="0.5"
            CornerRadius="{StaticResource CornerRadiusMd}"
            Padding="8,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Path Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                  Stroke="{StaticResource TextTertiary}" StrokeThickness="1.5"
                  Fill="Transparent"
                  Data="M9,9 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0 M13.5,13.5 L18,18"
                  VerticalAlignment="Center" Margin="0,0,6,0"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding Placeholder, ElementName=Root}"
                       Foreground="{StaticResource TextTertiary}"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       FontStyle="Italic"
                       TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=Root}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Text, ElementName=Root}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBox x:Name="Input" Grid.Column="1"
                     Text="{Binding Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     Style="{StaticResource SearchInputTextBox}"/>

            <ContentPresenter Grid.Column="2"
                              Content="{Binding TrailingContent, ElementName=Root}"
                              VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
