<UserControl x:Class="Gitster.Controls.HistoryRewriteDraftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HistoryRewriteDraftViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Width="13"
                      Height="13"
                      Stretch="Uniform"
                      Stroke="{StaticResource TextSecondary}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M4,12 L4,17 L9,17 L18,8 L13,3 Z M12,4 L17,9"
                      Margin="0,1,6,0"
                      VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="History edit"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding AffectedRewriteCount}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasDrafts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <StackPanel IsEnabled="{Binding IsSelectedCommitEditable}">
                <TextBlock Text="Message"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiary}"
                           Margin="0,0,0,3"/>
                <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="74"
                         FontSize="12"
                         Margin="0,0,0,8"
                         BorderBrush="{StaticResource BorderTertiary}"
                         Foreground="{StaticResource TextPrimary}"
                         Background="{StaticResource BackgroundPrimary}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Author"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiary}"
                                   Margin="0,0,0,3"/>
                        <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28"
                                 FontSize="12"
                                 BorderBrush="{StaticResource BorderTertiary}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Background="{StaticResource BackgroundPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiary}"
                                   Margin="0,0,0,3"/>
                        <TextBox Text="{Binding AuthorEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28"
                                 FontSize="12"
                                 BorderBrush="{StaticResource BorderTertiary}"
                                 Foreground="{StaticResource TextPrimary}"
                                 Background="{StaticResource BackgroundPrimary}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Timestamp"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiary}"
                           Margin="0,0,0,3"/>
                <controls:DateControl SelectedDate="{Binding AuthorDate, Mode=TwoWay}"
                                      EditMode="DateTime"
                                      Height="30"
                                      Margin="0,0,0,6"/>

                <CheckBox IsChecked="{Binding UpdateCommitterTimestamp}"
                          Content="Update committer timestamp"
                          FontSize="11"
                          Foreground="{StaticResource TextSecondary}"
                          Margin="0,0,0,8"/>
            </StackPanel>

            <Border Padding="8,6"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Margin="0,0,0,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasRemoteRewriteRisk}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentWarningBackground}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentWarning}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasLocalOnlyCleanup}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentInfoBackground}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"/>
            </Border>

            <StackPanel>
                <Button Command="{Binding ApplyCommand}"
                        IsEnabled="{Binding CanApply}"
                        Height="34"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Path Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  Data="M4,11 L8,15 L17,5"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Apply edits"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Command="{Binding ResetSelectedCommand}"
                        IsEnabled="{Binding CanDiscardSelected}"
                        Height="34"
                        Margin="0,6,0,0"
                        ToolTip="Discard selected commit edit"
                        Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="13"
                              Height="13"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M5,5 L15,15 M15,5 L5,15"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Discard selected edit"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearAllCommand}"
                        IsEnabled="{Binding HasDrafts}"
                        Height="34"
                        Margin="0,6,0,0"
                        ToolTip="Discard all history edits"
                        Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M5,6 L15,16 M15,6 L5,16 M7,4 L13,4 M8,4 L8,3 L12,3 L12,4"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Discard all edits"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
