<UserControl x:Class="Gitster.Controls.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TitleBarViewModel}">

    <Border Background="{StaticResource AccentBlue}"
            BorderThickness="0">

        <Grid Height="42">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: folder icon · repo name · branch -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="📂" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding RepositoryName}"
                           FontWeight="Medium"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" · "
                           Foreground="#80FFFFFF"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentBranch}"
                           FontFamily="{StaticResource FontFamilyMono}"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: ↓ incoming  ↑ outgoing  [Switch repo] -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,12,0">

                <!-- ↓ Incoming -->
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="↓" FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasIncoming}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding IncomingCount}"
                               Margin="2,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasIncoming}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentSuccess}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- ↑ Outgoing -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="↑" FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOutgoing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding OutgoingCount}"
                               Margin="2,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOutgoing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ToggleButton IsChecked="{Binding AutoFetchEnabled}"
                              Width="28" Height="28"
                              Background="Transparent" BorderThickness="0"
                              ToolTip="{Binding AutoFetchTooltip}"
                              Margin="0,0,8,0">
                    <Grid>
                        <Path Stretch="Uniform" Width="14" Height="14"
                              Stroke="White" StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M3,10 a7,7 0 0,1 14,0 M17,10 L14,7 M17,10 L20,7 M17,10 a7,7 0 0,1 -14,0 M3,10 L6,13 M3,10 L0,13"/>
                        <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentSuccess}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,2,2,0"
                                 Visibility="{Binding AutoFetchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </ToggleButton>

                <Button Content="Switch repo"
                        Command="{Binding BrowseFolderCommand}"
                        Foreground="White"
                        BorderBrush="#50FFFFFF"
                        Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
