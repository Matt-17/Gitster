<UserControl x:Class="Gitster.Controls.TitleBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TitleBarViewModel}">

    <UserControl.Resources>
        <Style x:Key="TitleBarSplitButtonPart" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecentRepoTextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4,6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecentRepoPinButton" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B8D8F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecentRepoListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                HorizontalAlignment="Stretch">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F3FC"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlueBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D8ECFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource AccentBlue}"
            BorderThickness="0">

        <Grid Height="42">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: folder icon · repo name · branch -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="📂" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding RepositoryName}"
                           FontWeight="Medium"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" · "
                           Foreground="#80FFFFFF"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentBranch}"
                           FontFamily="{StaticResource FontFamilyMono}"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: ↓ incoming  ↑ outgoing  [Switch repo] -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,12,0">

                <!-- ↓ Incoming -->
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <TextBlock Text="↓" FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasIncoming}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding IncomingCount}"
                               Margin="2,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasIncoming}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentSuccess}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- ↑ Outgoing -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="↑" FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOutgoing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding OutgoingCount}"
                               Margin="2,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOutgoing}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentWarning}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ToggleButton IsChecked="{Binding AutoFetchEnabled}"
                              Width="28" Height="28"
                              Background="Transparent" BorderThickness="0"
                              ToolTip="{Binding AutoFetchTooltip}"
                              Margin="0,0,8,0">
                    <Grid>
                        <Path Stretch="Uniform" Width="14" Height="14"
                              Stroke="White" StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M3,10 a7,7 0 0,1 14,0 M17,10 L14,7 M17,10 L20,7 M17,10 a7,7 0 0,1 -14,0 M3,10 L6,13 M3,10 L0,13"/>
                        <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentSuccess}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,2,2,0"
                                 Visibility="{Binding AutoFetchEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </ToggleButton>

                <!-- SplitButton: left = Switch repo, right = recent-repos chevron -->
                <Border x:Name="RepoSplitButton"
                        BorderBrush="#50FFFFFF"
                        BorderThickness="0.5"
                        CornerRadius="4"
                        Background="#26FFFFFF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>

                        <!-- Main action: opens folder browser -->
                        <Button Grid.Column="0"
                                Style="{StaticResource TitleBarSplitButtonPart}"
                                Command="{Binding BrowseFolderCommand}"
                                Padding="10,0,8,0"
                                ToolTip="Open repository (Ctrl+O)">
                            <TextBlock Text="Switch repo" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Divider -->
                        <Rectangle Grid.Column="1" Fill="#50FFFFFF" VerticalAlignment="Stretch" Margin="0,4"/>

                        <!-- Chevron: opens recent-repos dropdown -->
                        <Button x:Name="RepoDropdownBtn"
                                Grid.Column="2"
                                Style="{StaticResource TitleBarSplitButtonPart}"
                                Command="{Binding OpenRecentRepositoriesPopupCommand}"
                                Width="24"
                                ToolTip="Recent repositories">
                            <!-- Down chevron -->
                            <Path Width="8" Height="5"
                                  Data="M0,0 L4,4 L8,0"
                                  Stroke="White" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"/>
                        </Button>

                        <Popup x:Name="RecentRepositoriesPopup"
                               Grid.ColumnSpan="3"
                               PlacementTarget="{Binding ElementName=RepoSplitButton}"
                               Placement="Bottom"
                               HorizontalOffset="-188"
                               VerticalOffset="6"
                               AllowsTransparency="True"
                               StaysOpen="False"
                               Focusable="False"
                               Opened="RecentRepositoriesPopup_Opened"
                               IsOpen="{Binding IsRecentRepositoriesPopupOpen, Mode=TwoWay}">
                            <Border Width="320"
                                    Background="{StaticResource BackgroundPrimary}"
                                    BorderBrush="{StaticResource BorderTertiary}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="6"
                                    PreviewKeyDown="RecentRepositoriesPopup_PreviewKeyDown"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="4"
                                                      Direction="270"
                                                      Opacity="0.22"
                                                      Color="#000000"/>
                                </Border.Effect>
                                <Grid>
                                    <ListBox x:Name="RecentRepositoriesList"
                                             HorizontalContentAlignment="Stretch"
                                             ItemsSource="{Binding RecentRepositoryItems}"
                                             SelectedItem="{Binding SelectedRecentRepository, Mode=TwoWay}"
                                             ItemContainerStyle="{StaticResource RecentRepoListBoxItem}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             KeyboardNavigation.DirectionalNavigation="Contained"
                                             Visibility="{Binding HasRecentRepositories, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ListBox.InputBindings>
                                            <KeyBinding Key="Enter"
                                                        Command="{Binding OpenSelectedRecentRepoCommand}"/>
                                            <KeyBinding Key="Escape"
                                                        Command="{Binding CloseRecentRepositoriesPopupCommand}"/>
                                        </ListBox.InputBindings>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="36"
                                                      HorizontalAlignment="Stretch"
                                                      Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="3"
                                                            Height="20"
                                                            CornerRadius="2"
                                                            Background="{StaticResource AccentBlue}"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                    <Button Grid.Column="1"
                                                            Style="{StaticResource RecentRepoTextButton}"
                                                            Command="{Binding DataContext.OpenRecentRepoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding FullPath}"
                                                            Focusable="False"          
                                                            ToolTip="{Binding FullPath}">
                                                        <Grid HorizontalAlignment="Stretch">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       TextAlignment="Left"
                                                                       HorizontalAlignment="Stretch"
                                                                       Foreground="{StaticResource TextPrimary}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding DisplayPath}"
                                                                       TextAlignment="Left"
                                                                       HorizontalAlignment="Stretch"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontFamily="{StaticResource FontFamilyMono}"
                                                                       FontSize="10"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Button>

                                                    <Button Grid.Column="2"
                                                            Command="{Binding DataContext.TogglePinRepoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding FullPath}"
                                                            Focusable="False"
                                                            ToolTip="{Binding PinTooltip}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource RecentRepoPinButton}">
                                                                <Setter Property="Opacity" Value="0.58"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Path x:Name="PinIcon"
                                                              Width="13"
                                                              Height="13"
                                                              Stretch="Uniform"
                                                              Data="M8,1 L12,5 L10,7 L12,10 L10,12 L7,9 L3,13 L1,11 L5,7 L2,4 L4,2 L7,5 Z"
                                                              StrokeThickness="1.2"
                                                              StrokeLineJoin="Round">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="{StaticResource TextTertiary}"/>
                                                                    <Setter Property="Fill" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                            <Setter Property="Stroke" Value="{StaticResource AccentBlue}"/>
                                                                            <Setter Property="Fill" Value="{StaticResource AccentBlue}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Visibility="{Binding HasRecentRepositories, Converter={StaticResource InverseBoolVisibilityConverter}}"
                                                MinHeight="88"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="No recent repositories"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,12,0,6"/>
                                        <Button Content="Open repository..."
                                                Style="{StaticResource GhostButton}"
                                                Command="{Binding BrowseFolderCommand}"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,10"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
