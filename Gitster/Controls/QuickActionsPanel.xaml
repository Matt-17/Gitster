<UserControl x:Class="Gitster.Controls.QuickActionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:helper="clr-namespace:Gitster.Views.Helper"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:QuickActionsViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Path Width="12" Height="12" Stretch="Uniform"
                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M13,2 L7,12 L11,12 L7,22 L17,10 L13,10 Z"
                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="More actions"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 2×2 action grid (expanded to 2×3 for Squash) -->
            <UniformGrid Rows="3" Columns="2">
                <Button Content="Reword"
                        Command="{Binding RewordCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Reword the selected commit's message</Button.ToolTip>
                </Button>
                <Button Content="Cherry-pick"
                        Command="{Binding CherryPickCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Cherry-pick a commit from another branch</Button.ToolTip>
                </Button>
                <Button Content="Author"
                        Command="{Binding ChangeAuthorCommand}"
                        ToolTip="Coming in Phase 2"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch"/>
                <Button Content="Fixup"
                        helper:Capability.Requires="FixupAutosquash"
                        Command="{Binding FixupCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Stage fixup into the selected commit (requires Git CLI)</Button.ToolTip>
                </Button>
                <Button Content="Squash"
                        Command="{Binding SquashSelectedCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Squash selected commits into one (select 2+ in the list)</Button.ToolTip>
                </Button>
            </UniformGrid>

        </StackPanel>
    </Border>
</UserControl>
