<UserControl x:Class="Gitster.Controls.QuickActionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:helper="clr-namespace:Gitster.Views.Helper"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:QuickActionsViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <Expander IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                          Fill="Transparent"
                          Data="{StaticResource IconLightningGeometry}"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="More actions"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Expander.Header>

            <UniformGrid Rows="3" Columns="2" Margin="0,8,0,0">
                <Button Content="Cherry-pick"
                        Command="{Binding CherryPickCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Cherry-pick a commit from another branch</Button.ToolTip>
                </Button>
                <Button Content="Fixup"
                        helper:Capability.Requires="FixupAutosquash"
                        Command="{Binding FixupCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Stage fixup into the selected commit (requires Git CLI)</Button.ToolTip>
                </Button>
                <Button Content="To branch..."
                        Command="{Binding CommitToBranchCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Commit your changes onto another branch without switching</Button.ToolTip>
                </Button>
                <Button Content="Snapshot..."
                        Command="{Binding SnapshotToBranchCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Save the current state as a named branch</Button.ToolTip>
                </Button>
                <Button Content="Archive commit..."
                        helper:Capability.Requires="SourceArchive"
                        Command="{Binding ArchiveSelectedCommitCommand}"
                        ToolTipService.ShowOnDisabled="True"
                        Style="{StaticResource GhostButton}"
                        Height="32" Margin="0,0,4,4"
                        HorizontalAlignment="Stretch">
                    <Button.ToolTip>Export the selected commit as a source ZIP</Button.ToolTip>
                </Button>
            </UniformGrid>
        </Expander>
    </Border>
</UserControl>
