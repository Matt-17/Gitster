<UserControl x:Class="Gitster.Controls.QuickActionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:QuickActionsViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Path Width="12" Height="12" Stretch="Uniform"
                      Stroke="{StaticResource TextSecondary}" StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M13,2 L7,12 L11,12 L7,22 L17,10 L13,10 Z"
                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="More actions"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 2×2 action grid -->
            <ItemsControl ItemsSource="{Binding Actions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="2" Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button IsEnabled="{Binding IsAvailable}"
                                ToolTip="Coming in Phase 2"
                                ToolTipService.ShowOnDisabled="True"
                                Style="{StaticResource GhostButton}"
                                Height="32"
                                Margin="0,0,4,4"
                                HorizontalAlignment="Stretch">
                            <TextBlock Text="{Binding Label}" FontSize="12"/>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
