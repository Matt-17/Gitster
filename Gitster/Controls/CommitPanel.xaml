<UserControl x:Class="Gitster.Controls.CommitPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitPanelViewModel}"
             Width="440">
    <UserControl.Resources>
        <!-- A file row: checkbox · badge · path · +/- counts -->
        <DataTemplate x:Key="FileRowTemplate">
            <Grid Height="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding IsStaged, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="2" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource AccentBlueBackground}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Badge}" Value="A"><Setter Property="Background" Value="{StaticResource AccentSuccessBackground}"/></DataTrigger>
                                <DataTrigger Binding="{Binding Badge}" Value="U"><Setter Property="Background" Value="{StaticResource AccentSuccessBackground}"/></DataTrigger>
                                <DataTrigger Binding="{Binding Badge}" Value="D"><Setter Property="Background" Value="{StaticResource AccentDangerBackground}"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Badge}" FontFamily="{StaticResource FontFamilyMono}"
                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                </Border>
                <TextBlock Grid.Column="2" Text="{Binding Path}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontFamily="{StaticResource FontFamilyMono}" FontSize="11"
                           TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontFamily="{StaticResource FontFamilyMono}" FontSize="10">
                    <Run Text="+" Foreground="{StaticResource AccentSuccess}"/><Run Text="{Binding Added, Mode=OneWay}" Foreground="{StaticResource AccentSuccess}"/><Run Text=" −" Foreground="{StaticResource AccentDanger}"/><Run Text="{Binding Deleted, Mode=OneWay}" Foreground="{StaticResource AccentDanger}"/>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundPrimary}"
            BorderBrush="{StaticResource BorderTertiary}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="90" Opacity="0.22" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Commit" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimary}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource TextTertiary}" Margin="0,0,8,0"/>
                    <Button Width="22" Height="22" Padding="0" Style="{StaticResource IconButton}"
                            Command="{Binding CloseCommand}" ToolTip="Close (Esc)">
                        <Path Width="9" Height="9" Stretch="Uniform" Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5" Data="M2,2 L10,10 M10,2 L2,10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Message -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BorderTertiary}" BorderThickness="0.5"
                    CornerRadius="6" Padding="2" Margin="0,0,0,6">
                <Grid>
                    <TextBlock Text="Message (required)" Foreground="{StaticResource TextTertiary}"
                               Margin="6,4" FontStyle="Italic" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Message}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="54" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent"
                             Padding="6,4" Foreground="{StaticResource TextPrimary}"/>
                </Grid>
            </Border>

            <!-- Amend + author -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <CheckBox Content="Amend last commit" IsChecked="{Binding AmendLastCommit}"
                          VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}"
                        Padding="8,3" FontSize="11"
                        Command="{Binding EditAuthorCommand}"
                        Content="{Binding AuthorLabel}" ToolTip="Override author/committer for this commit"/>
            </Grid>

            <!-- Staged section -->
            <Grid Grid.Row="3" Margin="0,0,0,4"
                  Visibility="{Binding HasStaged, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <TextBlock Text="Staged" FontWeight="Medium" FontSize="11" Foreground="{StaticResource AccentSuccess}"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Padding="6,1" FontSize="10"
                            Content="Unstage all" Command="{Binding UnstageAllCommand}"/>
                </Grid>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Staged}" ItemTemplate="{StaticResource FileRowTemplate}"
                              MaxHeight="120"/>
            </Grid>

            <!-- Changes section -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,2,0,2">
                    <TextBlock Text="Changes" FontWeight="Medium" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Padding="6,1" FontSize="10"
                            Content="Stage all" Command="{Binding StageAllCommand}"
                            Visibility="{Binding HasChanges, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Changes}" ItemTemplate="{StaticResource FileRowTemplate}"/>
                        <TextBlock Text="No changes" Foreground="{StaticResource TextTertiary}" FontStyle="Italic"
                                   Margin="2,6" Visibility="{Binding HasChanges, Converter={StaticResource InverseBoolVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Footer: Commit split button + Stash split button -->
            <Grid Grid.Row="5" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Commit split button -->
                <Grid Grid.Column="0" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" MinWidth="120"
                            Content="Commit" Command="{Binding CommitCommand}"/>
                    <ToggleButton x:Name="CommitMore" Grid.Column="1" Margin="3,0,0,0" Width="26"
                                  Background="{StaticResource AccentBlue}" Foreground="White" BorderThickness="0"
                                  ToolTip="More commit actions">
                        <Path Width="8" Height="5" Data="M0,0 L4,4 L8,0" Stroke="White" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=CommitMore}" PlacementTarget="{Binding ElementName=CommitMore}"
                           Placement="Top" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{StaticResource BackgroundPrimary}" BorderBrush="{StaticResource BorderTertiary}"
                                BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="200">
                            <StackPanel>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                        BorderThickness="0" Content="Commit and push  (Ctrl+Enter)"
                                        Command="{Binding CommitAndPushCommand}"
                                        Click="ClosePopup"/>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                        BorderThickness="0" Content="Commit and sync"
                                        Command="{Binding CommitAndSyncCommand}"
                                        Click="ClosePopup"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Stash split button -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource GhostButton}" Content="Stash"
                            Command="{Binding StashAllCommand}"/>
                    <ToggleButton x:Name="StashMore" Grid.Column="1" Margin="3,0,0,0" Width="26"
                                  Style="{x:Null}" Background="Transparent"
                                  BorderBrush="{StaticResource BorderSecondary}" BorderThickness="1"
                                  ToolTip="More stash actions">
                        <Path Width="8" Height="5" Data="M0,0 L4,4 L8,0" Stroke="{StaticResource TextSecondary}"
                              StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" Fill="Transparent"/>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=StashMore}" PlacementTarget="{Binding ElementName=StashMore}"
                           Placement="Top" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{StaticResource BackgroundPrimary}" BorderBrush="{StaticResource BorderTertiary}"
                                BorderThickness="1" CornerRadius="6" Padding="4" MinWidth="200">
                            <StackPanel>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                        BorderThickness="0" Content="Stash all (incl. untracked)"
                                        Command="{Binding StashAllCommand}" Click="ClosePopup"/>
                                <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                        BorderThickness="0" Content="Stash &amp; keep staged"
                                        Command="{Binding StashKeepStagedCommand}" Click="ClosePopup"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
