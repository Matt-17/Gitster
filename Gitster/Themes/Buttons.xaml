<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── PrimaryButton ─────────────────────────────────────────── -->
    <!-- Accent background, white text. Used for "Amend ausführen".  -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"  Value="{StaticResource AccentBlue}"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"     Value="12,6"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontFamilyUi}"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#005FA3"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#004F87"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource BorderTertiary}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── GhostButton ───────────────────────────────────────────── -->
    <!-- Transparent background, thin border, hover revealed.        -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderSecondary}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="10,5"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="FontFamily"       Value="{StaticResource FontFamilyUi}"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource BackgroundSecondary}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBlueBackground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BorderTertiary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── IconButton ────────────────────────────────────────────── -->
    <!-- Square ghost-style button, icon only, no visible text.      -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="Width"           Value="28"/>
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Padding"         Value="4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background"      Value="Transparent"/>
    </Style>

</ResourceDictionary>
