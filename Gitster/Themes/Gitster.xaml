<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Colours ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BackgroundPrimary"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundSecondary"  Color="#F5F5F5"/>
    <SolidColorBrush x:Key="BorderTertiary"       Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BorderSecondary"      Color="#BDBDBD"/>
    <SolidColorBrush x:Key="WindowBorderBrush"    Color="#8A8A8A"/>
    <SolidColorBrush x:Key="TextPrimary"          Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextSecondary"        Color="#555555"/>
    <SolidColorBrush x:Key="TextTertiary"         Color="#9E9E9E"/>
    <SolidColorBrush x:Key="AccentBlue"           Color="#007ACC"/>
    <SolidColorBrush x:Key="AccentBlueBackground" Color="#CCE4F7"/>
    <SolidColorBrush x:Key="AccentWarning"           Color="#D97706"/>
    <SolidColorBrush x:Key="AccentSuccess"           Color="#16A34A"/>
    <SolidColorBrush x:Key="AccentDanger"            Color="#DC2626"/>
    <SolidColorBrush x:Key="AccentWarningBackground" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="AccentDangerBackground"  Color="#FEE2E2"/>
    <SolidColorBrush x:Key="AccentSuccessBackground" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="AccentInfoBackground"    Color="#DBEAFE"/>
    <SolidColorBrush x:Key="IncomingHeaderBackground" Color="#F7FBFF"/>
    <SolidColorBrush x:Key="OutgoingHeaderBackground" Color="#FFFCF2"/>
    <SolidColorBrush x:Key="SoftDisabledBackground"   Color="#FAFAFA"/>

    <!-- ── Spacing ────────────────────────────────────────────────── -->
    <sys:Double  x:Key="PaddingSm">6</sys:Double>
    <sys:Double  x:Key="PaddingMd">10</sys:Double>
    <sys:Double  x:Key="PaddingLg">14</sys:Double>
    <sys:Double  x:Key="RadiusMd">8</sys:Double>
    <sys:Double  x:Key="RadiusLg">12</sys:Double>
    <CornerRadius x:Key="TextInputCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>

    <Thickness x:Key="PaddingSmThickness">6</Thickness>
    <Thickness x:Key="PaddingMdThickness">10</Thickness>
    <Thickness x:Key="PaddingLgThickness">14</Thickness>

    <!-- ── Typography ────────────────────────────────────────────── -->
    <FontFamily x:Key="FontFamilyUi">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Cascadia Mono, JetBrains Mono, Consolas</FontFamily>

    <Style x:Key="GitsterTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource BackgroundPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderTertiary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUi}"/>
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource TextInputCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentDanger}"/>
                        </Trigger>
                        <Trigger Property="AcceptsReturn" Value="True">
                            <Setter Property="Padding" Value="4,3"/>
                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource SoftDisabledBackground}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderTertiary}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource GitsterTextBox}"/>

</ResourceDictionary>
