<UserControl x:Class="Gitster.Controls.DateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Gitster.Behaviors"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:viewModels="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewModels:DateControlViewModel}"
             d:DesignWidth="300" HorizontalAlignment="Stretch"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="GhostIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PopupTriggerButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>

        <Style x:Key="DatePartTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource GitsterTextBox}">
            <Setter Property="Padding" Value="0,1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUi}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <StackPanel x:Name="LayoutRoot" Orientation="Horizontal">
        <Border x:Name="InputFrame"
                Height="30"
                Background="{DynamicResource BackgroundPrimary}"
                Padding="6,0"
                CornerRadius="{DynamicResource TextInputCornerRadius}"
                SnapsToDevicePixels="True"
                VerticalAlignment="Center">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderTertiary}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding ElementName=TbDate, Path=(Validation.HasError)}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentDanger}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=TbTime, Path=(Validation.HasError)}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentDanger}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbDate" Grid.Column="0" 
                         Text="{Binding DateText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         MinWidth="70"
                         AutomationProperties.Name="Date"
                         PreviewMouseDoubleClick="TbDate_MouseDoubleClick" 
                         PreviewKeyDown="TbDate_PreviewKeyDown" 
                         PreviewMouseWheel="TbDate_PreviewMouseWheel"
                         GotKeyboardFocus="TbDate_GotFocus"  
                         LostKeyboardFocus="TbDate_LostFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource DatePartTextBoxStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    <b:Interaction.Behaviors>
                        <behaviors:FocusBehavior SelectOnFocus="True" />
                    </b:Interaction.Behaviors>
                </TextBox>
                <TextBox x:Name="TbTime" Grid.Column="1" 
                         Text="{Binding TimeText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         MinWidth="45"
                         AutomationProperties.Name="Time"
                         PreviewMouseDoubleClick="TbDate_MouseDoubleClick" 
                         PreviewKeyDown="TbTime_PreviewKeyDown" 
                         PreviewMouseWheel="TbTime_PreviewMouseWheel"
                         GotKeyboardFocus="TbDate_GotFocus"  
                         LostKeyboardFocus="TbDate_LostFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource DatePartTextBoxStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.DateTime}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    <b:Interaction.Behaviors>
                        <behaviors:FocusBehavior SelectOnFocus="True" />
                    </b:Interaction.Behaviors>
                </TextBox>
                <Button Grid.Column="2"
                        Click="Button_Click"
                        Style="{StaticResource PopupTriggerButtonStyle}"
                        AutomationProperties.Name="Open calendar">
                    <Path Stretch="Uniform"
                          Width="14"
                          Height="14"
                          StrokeThickness="1.5"
                          Fill="Transparent"
                          Data="M3,5 L17,5 L17,17 L3,17 Z M3,8 L17,8 M7,3 L7,7 M13,3 L13,7">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Stroke" Value="{DynamicResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
            </Grid>
        </Border>

        <!-- TODO: phase-2 i18n -->
        <Button Click="Today_Click"
                Margin="4,0,0,0"
                AutomationProperties.Name="Today"
                ToolTip="Today (H)">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid Width="14" Height="14">
                <Path Stretch="Uniform"
                      Stroke="{DynamicResource TextSecondary}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M3,5 L17,5 L17,17 L3,17 Z M7,3 L7,7 M13,3 L13,7"/>
                <Ellipse Width="4"
                         Height="4"
                         Fill="{DynamicResource AccentBlue}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,2,0,0"/>
            </Grid>
        </Button>

        <!-- TODO: phase-2 i18n -->
        <Button Click="Tomorrow_Click"
                Margin="4,0,0,0"
                AutomationProperties.Name="Tomorrow"
                ToolTip="Tomorrow (M)">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource GhostIconButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid Width="14" Height="14">
                <Path Stretch="Uniform"
                      Stroke="{DynamicResource TextSecondary}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M3,5 L17,5 L17,17 L3,17 Z M7,3 L7,7 M13,3 L13,7"/>
                <Path Stretch="Uniform"
                      Stroke="{DynamicResource AccentBlue}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M7,12 L13,12 M11,10 L13,12 L11,14"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,2,0,0"
                      Width="6"
                      Height="4"/>
            </Grid>
        </Button>

        <Popup x:Name="DatePopup" IsOpen="{Binding IsOpen, Mode=TwoWay}" StaysOpen="False" 
               Placement="Bottom" PlacementTarget="{Binding ElementName=InputFrame}" VerticalOffset="2"
               AllowsTransparency="True" PopupAnimation="Slide">
            <Border Background="Transparent" Padding="0,0,8,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                </Border.Effect>
                <controls:DatePickerPopup x:Name="PopupContent" DataContext="{Binding}" />
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
