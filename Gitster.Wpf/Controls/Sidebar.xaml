<UserControl x:Class="Gitster.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:models="clr-namespace:Gitster.Core.Models;assembly=Gitster.Core"
             d:DataContext="{d:DesignInstance Type=vm:SidebarViewModel}"
             mc:Ignorable="d"
             Width="44">

    <UserControl.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentMainLightestBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource BorderTertiary}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource BackgroundSecondary}">
        <StackPanel Orientation="Vertical">

            <!-- Commits (Ctrl+1) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.Commits}"
                    AutomationProperties.Name="Commits"
                    ToolTip="Commits  Ctrl+1">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsCommitsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconCommitsGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCommitsActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Grid>
            </Button>

            <!-- Stashes (Ctrl+2) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.Stashes}"
                    AutomationProperties.Name="Stashes"
                    ToolTip="Stashes  Ctrl+2">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsStashesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconStashesGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStashesActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                    <!-- Badge dot -->
                    <Border Width="6" Height="6" CornerRadius="3"
                            Background="{DynamicResource AccentBlue}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,9,9,0"
                            Visibility="{Binding HasStashBadge, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Button>

            <!-- Branches (Ctrl+3) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.Branches}"
                    AutomationProperties.Name="Branches"
                    ToolTip="Branches  Ctrl+3">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsBranchesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconBranchesGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBranchesActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                    <!-- Badge dot -->
                    <Border Width="6" Height="6" CornerRadius="3"
                            Background="{DynamicResource AccentBlue}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,9,9,0"
                            Visibility="{Binding HasBranchBadge, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Button>

            <!-- Worktrees (Ctrl+4) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.Worktrees}"
                    AutomationProperties.Name="Worktrees"
                    ToolTip="Worktrees  Ctrl+4">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsWorktreesActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconWorktreesGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWorktreesActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Grid>
            </Button>

            <!-- Search (Ctrl+5) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.Search}"
                    AutomationProperties.Name="Search"
                    ToolTip="Search  Ctrl+5">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsSearchActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconSearchGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Grid>
            </Button>

            <!-- Operations Log (Ctrl+6) -->
            <Button Height="44" Style="{StaticResource SidebarButton}"
                    Command="{Binding SelectModeCommand}"
                    CommandParameter="{x:Static models:AppMode.OperationsLog}"
                    AutomationProperties.Name="Operations log"
                    ToolTip="Operations log  Ctrl+6">
                <Grid Width="44" Height="44">
                    <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{DynamicResource AccentBlue}"
                               Visibility="{Binding IsOperationsLogActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Path Data="{StaticResource IconOperationsLogGeometry}">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource StrokeIcon16}">
                                <Setter Property="Stroke" Value="{DynamicResource TextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOperationsLogActive}" Value="True">
                                        <Setter Property="Stroke" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                    <!-- Badge dot -->
                    <Border Width="6" Height="6" CornerRadius="3"
                            Background="{DynamicResource AccentBlue}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,9,9,0"
                            Visibility="{Binding HasOpsLogBadge, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Button>

        </StackPanel>
    </Border>
</UserControl>
