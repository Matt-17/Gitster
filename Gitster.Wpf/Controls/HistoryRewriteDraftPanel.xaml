<UserControl x:Class="Gitster.Controls.HistoryRewriteDraftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HistoryRewriteDraftViewModel}">

    <Border Style="{StaticResource PanelCard}">
        <StackPanel>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Width="13"
                      Height="13"
                      Stretch="Uniform"
                      Stroke="{DynamicResource TextSecondary}"
                      StrokeThickness="1.5"
                      Fill="Transparent"
                      Data="M4,12 L4,17 L9,17 L18,8 L13,3 Z M12,4 L17,9"
                      Margin="0,1,6,0"
                      VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center">
                    <Run Text="History edit"/><Run Text="{Binding SelectionSuffix, Mode=OneWay}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                </TextBlock>
                <TextBlock Grid.Column="2"
                           Text="{Binding AffectedRewriteCount}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasDrafts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <StackPanel IsEnabled="{Binding IsSelectedCommitEditable}">
                <Grid Margin="0,0,0,3">
                    <TextBlock Text="Message"
                               FontSize="10"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Content="Keep first line"
                            Command="{Binding KeepFirstMessageLineCommand}"
                            ToolTip="Drop everything below the subject line — applied to each selected commit separately"
                            Style="{StaticResource LinkTextButton}"/>
                </Grid>
                <Grid Margin="0,0,0,8"
                      ToolTip="Different values across the selected commits"
                      ToolTipService.IsEnabled="{Binding IsMessageMixed}">
                    <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="74"
                             FontSize="12"
                             BorderBrush="{DynamicResource BorderTertiary}"
                             Foreground="{DynamicResource TextPrimary}"
                             Background="{DynamicResource BackgroundPrimary}"/>
                    <Border Style="{StaticResource MixedValueOverlay}"
                            Visibility="{Binding IsMessageMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Author"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Margin="0,0,0,3"/>
                        <Grid ToolTip="Different values across the selected commits"
                              ToolTipService.IsEnabled="{Binding IsAuthorNameMixed}">
                            <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28"
                                     FontSize="12"
                                     BorderBrush="{DynamicResource BorderTertiary}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Background="{DynamicResource BackgroundPrimary}"/>
                            <Border Style="{StaticResource MixedValueOverlay}"
                                    Visibility="{Binding IsAuthorNameMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Margin="0,0,0,3"/>
                        <Grid ToolTip="Different values across the selected commits"
                              ToolTipService.IsEnabled="{Binding IsAuthorEmailMixed}">
                            <TextBox Text="{Binding AuthorEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28"
                                     FontSize="12"
                                     BorderBrush="{DynamicResource BorderTertiary}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Background="{DynamicResource BackgroundPrimary}"/>
                            <Border Style="{StaticResource MixedValueOverlay}"
                                    Visibility="{Binding IsAuthorEmailMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Author timestamp"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,3"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0"
                          ToolTip="Different dates across the selected commits"
                          ToolTipService.IsEnabled="{Binding IsAuthorDateMixed}">
                        <controls:DateControl SelectedDate="{Binding AuthorDatePart, Mode=TwoWay}"
                                              EditMode="DateOnly"
                                              Height="30"/>
                        <Border Style="{StaticResource MixedValueOverlay}"
                                Visibility="{Binding IsAuthorDateMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <Grid Grid.Column="2"
                          ToolTip="Different times across the selected commits"
                          ToolTipService.IsEnabled="{Binding IsAuthorTimeMixed}">
                        <controls:DateControl SelectedDate="{Binding AuthorTimePart, Mode=TwoWay}"
                                              EditMode="TimeOnly"
                                              Height="30"/>
                        <Border Style="{StaticResource MixedValueOverlay}"
                                Visibility="{Binding IsAuthorTimeMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Grid>

                <TextBlock Text="Committer timestamp"
                           FontSize="10"
                           Foreground="{DynamicResource TextTertiary}"
                           Margin="0,0,0,3"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0"
                          ToolTip="Different dates across the selected commits"
                          ToolTipService.IsEnabled="{Binding IsCommitterDateMixed}">
                        <controls:DateControl SelectedDate="{Binding CommitterDatePart, Mode=TwoWay}"
                                              EditMode="DateOnly"
                                              IsEnabled="{Binding IsCommitterTimestampEditable}"
                                              Height="30"/>
                        <Border Style="{StaticResource MixedValueOverlay}"
                                Visibility="{Binding IsCommitterDateMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <Grid Grid.Column="2"
                          ToolTip="Different times across the selected commits"
                          ToolTipService.IsEnabled="{Binding IsCommitterTimeMixed}">
                        <controls:DateControl SelectedDate="{Binding CommitterTimePart, Mode=TwoWay}"
                                              EditMode="TimeOnly"
                                              IsEnabled="{Binding IsCommitterTimestampEditable}"
                                              Height="30"/>
                        <Border Style="{StaticResource MixedValueOverlay}"
                                Visibility="{Binding IsCommitterTimeMixed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                    <Button Grid.Column="4"
                            Width="30"
                            Height="30"
                            Padding="0"
                            AutomationProperties.Name="Sync committer timestamp with author timestamp"
                            ToolTip="Take over the author timestamp"
                            IsEnabled="{Binding IsCommitterTimestampEditable}"
                            Command="{Binding SyncCommitterDateCommand}"
                            Style="{StaticResource GhostButton}">
                        <Path Width="13"
                              Height="13"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M16,5 A7,7 0 1 0 17,10 M17,4 L17,9 L12,9"/>
                    </Button>
                    <ToggleButton Grid.Column="6"
                                  IsChecked="{Binding SyncCommitterWithAuthor, Mode=TwoWay}"
                                  AutomationProperties.Name="Always follow the author timestamp"
                                  ToolTip="Keep the committer timestamp in step with every author timestamp change"
                                  Style="{StaticResource LinkToggleButton}">
                        <Path Width="13"
                              Height="13"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.5"
                              Data="M8,12 L12,8 M7.5,6.5 L9.5,4.5 A3.5,3.5 0 0 1 15.5,10.5 L13.5,12.5 M6.5,7.5 L4.5,9.5 A3.5,3.5 0 0 0 10.5,15.5 L12.5,13.5"/>
                    </ToggleButton>
                </Grid>
            </StackPanel>

            <Border Padding="8,6"
                    CornerRadius="{StaticResource CornerRadiusMd}"
                    Margin="0,0,0,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderTertiary}"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasRemoteRewriteRisk}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentWarningBackground}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentWarning}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasLocalOnlyCleanup}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentInfoBackground}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding SummaryText}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"/>
            </Border>

            <StackPanel>
                <Button Command="{Binding ApplyCommand}"
                        IsEnabled="{Binding CanApply}"
                        Height="34"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Path Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Fill="Transparent"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  Data="M4,11 L8,15 L17,5"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Apply edits"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Command="{Binding ResetSelectedCommand}"
                        IsEnabled="{Binding CanDiscardSelected}"
                        Height="34"
                        Margin="0,6,0,0"
                        ToolTip="Discard edits for the selected commits"
                        Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="13"
                              Height="13"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M5,5 L15,15 M15,5 L5,15"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Discard selected edits"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearAllCommand}"
                        IsEnabled="{Binding HasDrafts}"
                        Height="34"
                        Margin="0,6,0,0"
                        ToolTip="Discard all history edits"
                        Style="{StaticResource GhostButton}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              Data="M5,6 L15,16 M15,6 L5,16 M7,4 L13,4 M8,4 L8,3 L12,3 L12,4"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Discard all edits"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
