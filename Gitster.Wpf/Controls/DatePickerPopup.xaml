<UserControl x:Class="Gitster.Controls.DatePickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:Gitster.Models"
             xmlns:controls="clr-namespace:Gitster.Controls"
             xmlns:viewModels="clr-namespace:Gitster.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewModels:DateControlViewModel}"
             d:DesignHeight="300" d:DesignWidth="330">
    <UserControl.Resources>
        <Style x:Key="HoverSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <Trigger Property="Border.IsMouseOver" Value="True">
                    <Setter Property="Border.Background" Value="{DynamicResource BackgroundSecondary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource BackgroundPrimary}"
            BorderBrush="{DynamicResource BorderSecondary}"
            BorderThickness="0.5"
            CornerRadius="{DynamicResource CornerRadiusMd}"
            MinHeight="220"
            SnapsToDevicePixels="True"
            Padding="{DynamicResource PaddingMdThickness}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Click="PrevMonthButton_Click"
                            Style="{StaticResource GhostButtonStyle}"
                            AutomationProperties.Name="Previous month">
                        <Path Width="8"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M8,2 L2,8 L8,14"/>
                    </Button>

                    <!-- TODO: phase-2 i18n -->
                    <Border Grid.Column="1"
                            Margin="6,0"
                            MouseDown="MonthOnMouseDown"
                            MouseUp="OnMouseUp"
                            MouseEnter="OnMouseEnter"
                            MouseLeave="OnMouseLeave"
                            MouseWheel="MonthOnMouseWheel"
                            ToolTip="Click or scroll to change month&#x0a;Left click - back&#x0a;Right click - forward&#x0a;Mouse wheel - fine adjust"
                            ToolTipService.InitialShowDelay="0"
                            Style="{StaticResource HoverSurfaceStyle}">
                        <TextBlock Text="{Binding Date, StringFormat='MMMM yyyy'}"
                                   FontFamily="{DynamicResource FontFamilyUi}"
                                   FontSize="15"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Button Grid.Column="2"
                            Click="NextMonthButton_Click"
                            Style="{StaticResource GhostButtonStyle}"
                            AutomationProperties.Name="Next month">
                        <Path Width="8"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M2,2 L8,8 L2,14"/>
                    </Button>
                </Grid>

                <Border Background="{DynamicResource BackgroundPrimary}"
                        BorderBrush="{DynamicResource BorderTertiary}"
                        BorderThickness="0,0,0,0.5"
                        Padding="2,4,2,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <!-- TODO: phase-2 i18n -->
                        <TextBlock Grid.Column="0" Text="Mon" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="1" Text="Tue" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="2" Text="Wed" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="3" Text="Thu" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="4" Text="Fri" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Grid.Column="5" Text="Sat" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                        <TextBlock Grid.Column="6" Text="Sun" TextAlignment="Center" Width="32" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextTertiary}"/>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Days}" MaxWidth="224" Margin="0,6,0,0" MouseWheel="MonthOnMouseWheel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DateTimeHolder}">
                            <Border Width="32" Height="30" Style="{StaticResource HoverSurfaceStyle}" MouseDown="DayOnMouseDown">
                                <Grid>
                                    <Border x:Name="TodayRing"
                                            BorderBrush="{DynamicResource AccentBlue}"
                                            BorderThickness="0"
                                            CornerRadius="4"/>
                                    <Border x:Name="SelectedFill"
                                            Margin="0"
                                            CornerRadius="4"
                                            Background="Transparent"/>
                                    <TextBlock x:Name="DayText"
                                               Text="{Binding Date, StringFormat='dd'}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource FontFamilyUi}"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                    <Setter TargetName="TodayRing" Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelectedMonth}" Value="False">
                                    <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Date.DayOfWeek}" Value="Saturday">
                                    <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Date.DayOfWeek}" Value="Sunday">
                                    <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="SelectedFill" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                    <Setter TargetName="DayText" Property="Foreground" Value="{DynamicResource BackgroundPrimary}"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                                        <Condition Binding="{Binding IsToday}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="SelectedFill" Property="Margin" Value="1"/>
                                </MultiDataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <Border Grid.Column="1" Width="0.5" Background="{DynamicResource BorderTertiary}" Margin="10,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.DateTime}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Grid Grid.Column="2" Width="220">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.DateTime}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EditMode}" Value="{x:Static controls:EditMode.TimeOnly}">
                                <Setter Property="Width" Value="220"/>
                                <Setter Property="Margin" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid Grid.Row="0" Height="36" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TODO: phase-2 i18n -->
                    <Border Grid.Column="0"
                            MouseDown="HourOnMouseDown"
                            MouseUp="OnMouseUp"
                            MouseEnter="OnMouseEnter"
                            MouseLeave="OnMouseLeave"
                            MouseWheel="HourOnMouseWheel"
                            ToolTip="Click or scroll to change hour&#x0a;Left click - back&#x0a;Right click - forward&#x0a;Mouse wheel - fine adjust"
                            ToolTipService.InitialShowDelay="0"
                            Style="{StaticResource HoverSurfaceStyle}">
                        <TextBlock Text="{Binding Hour, StringFormat='00'}"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text=":"
                               Margin="8,0"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <!-- TODO: phase-2 i18n -->
                    <Border Grid.Column="2"
                            MouseDown="MinuteOnMouseDown"
                            MouseUp="OnMouseUp"
                            MouseEnter="OnMouseEnter"
                            MouseLeave="OnMouseLeave"
                            MouseWheel="MinuteOnMouseWheel"
                            ToolTip="Click or scroll to change minute&#x0a;Left click - back&#x0a;Right click - forward&#x0a;Mouse wheel - fine adjust"
                            ToolTipService.InitialShowDelay="0"
                            Style="{StaticResource HoverSurfaceStyle}">
                        <TextBlock Text="{Binding Minute, StringFormat='00'}"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource BackgroundPrimary}"
                        BorderBrush="{DynamicResource BorderTertiary}"
                        BorderThickness="0,0,0,0.5"
                        Padding="0,3"
                        Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <!-- TODO: phase-2 i18n -->
                        <TextBlock Grid.Column="0" Text="Hour" TextAlignment="Center" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                        <!-- TODO: phase-2 i18n -->
                        <TextBlock Grid.Column="1" Text="Minute" TextAlignment="Center" FontWeight="Medium" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl ItemsSource="{Binding Hours}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="6" Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:SelectableTextBlock
                                    Text="{Binding}"
                                    MouseDown="HourTextMouseDown"
                                    Width="24"
                                    Height="24"
                                    Value="{Binding DataContext.Hour, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Column="1" Width="0.5" Background="{DynamicResource BorderTertiary}" Margin="8,0"/>

                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Minutes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="6" Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:SelectableTextBlock
                                    Text="{Binding}" 
                                    MouseDown="MinuteTextMouseDown"
                                    Width="32"
                                    Height="24"
                                    Value="{Binding DataContext.Minute, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</UserControl>
