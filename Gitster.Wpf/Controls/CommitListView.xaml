<UserControl x:Class="Gitster.Controls.CommitListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Gitster.Controls"
             xmlns:vm="clr-namespace:Gitster.ViewModels"
             xmlns:converters="clr-namespace:Gitster.Converters"
             xmlns:git="clr-namespace:Gitster.Core.Git;assembly=Gitster.Core"
             xmlns:helper="clr-namespace:Gitster.Views.Helper"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CommitListViewModel}">

    <UserControl.Resources>
        <converters:DateDisplayConverter x:Key="DateCellConverter"/>
        <converters:DateDisplayConverter x:Key="DateTooltipConverter" Invert="True"/>
        <Geometry x:Key="HistoryEditMessageGlyph">M4,5 H16 M4,10 H14 M4,15 H11</Geometry>
        <Geometry x:Key="HistoryEditAuthorGlyph">M10,4 A3,3 0 1 1 10,10 A3,3 0 1 1 10,4 M4,17 C5,13 15,13 16,17</Geometry>
        <Geometry x:Key="HistoryEditTimeGlyph">M10,3 A7,7 0 1 1 10,17 A7,7 0 1 1 10,3 M10,6 V10 L13,12</Geometry>
        <Geometry x:Key="HistoryEditFileGlyph">M6,3 H12 L16,7 V17 H6 Z M12,3 V7 H16</Geometry>
        <Geometry x:Key="HistoryEditTransitiveGlyph">M4,10 H15 M11,6 L15,10 L11,14</Geometry>

        <Style x:Key="CommitItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="CommitItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="PreviewMouseMove" Handler="CommitItem_PreviewMouseMove"/>
            <EventSetter Event="DragOver" Handler="CommitItem_DragOver"/>
            <EventSetter Event="DragLeave" Handler="CommitItem_DragLeave"/>
            <EventSetter Event="Drop" Handler="CommitItem_Drop"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="CommitItem_PreviewMouseRightButtonDown"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu DataContext="{Binding PlacementTarget, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Checkout (--detach)"
                                  Command="{Binding Tag.CheckoutCommitDetachedCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="View Commit Details"
                                  Command="{Binding Tag.ViewCommitDetailsCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="Open in Browser"
                                  Command="{Binding Tag.OpenCommitInBrowserCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <Separator/>
                        <MenuItem Header="Push through this commit"
                                  Command="{Binding Tag.PushThroughCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="Rewind remote to this commit"
                                  Command="{Binding Tag.ForceRemoteToCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="Push Tag"
                                  Command="{Binding Tag.PushTagCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <Separator/>
                        <MenuItem Header="Compare Commits..."
                                  Command="{Binding Tag.CompareSelectedCommitsCommand}"/>
                        <Separator/>
                        <MenuItem Header="New Branch..."
                                  Command="{Binding Tag.NewBranchFromCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="New Tag..."
                                  Command="{Binding Tag.NewTagFromCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <Separator/>
                        <MenuItem Header="Revert"
                                  Command="{Binding Tag.RevertCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="Reset">
                            <MenuItem Header="Reset branch here (--mixed, keep changes)"
                                      Command="{Binding Tag.ResetToCommitMixedCommand}"
                                      CommandParameter="{Binding DataContext}"/>
                            <MenuItem Header="Reset branch here (--hard, delete changes)"
                                      Command="{Binding Tag.ResetToCommitHardCommand}"
                                      CommandParameter="{Binding DataContext}"/>
                        </MenuItem>
                        <MenuItem Header="Cherry-Pick"
                                  Command="{Binding Tag.CherryPickCommitCommand}"
                                  CommandParameter="{Binding DataContext}"/>
                        <MenuItem Header="Squash Commits..."
                                  Command="{Binding Tag.QuickActionsVM.SquashSelectedCommand}"/>
                        <Separator/>
                        <MenuItem Header="Go to Child"
                                  InputGestureText="Alt+PgUp"
                                  Command="{Binding Tag.CommitListVM.SelectChildCommitCommand}"/>
                        <MenuItem Header="Go to Parent"
                                  InputGestureText="Alt+PgDn"
                                  Command="{Binding Tag.CommitListVM.SelectParentCommitCommand}"/>
                        <Separator/>
                        <MenuItem Header="Refresh"
                                  Command="{Binding Tag.RefreshCommand}"/>
                        <MenuItem Header="Show Outgoing / Incoming Only"
                                  IsCheckable="True"
                                  StaysOpenOnClick="True"
                                  IsChecked="{Binding Tag.CommitListVM.ShowOutgoingIncomingOnly, Mode=TwoWay}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommitPrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CommitSecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CommitMonoTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CommitSecondaryTextStyle}">
            <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="CommitRefLabelStyle" TargetType="Border">
            <Setter Property="Height" Value="16"/>
            <Setter Property="MaxWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static git:CommitRefKind.RemoteBranch}">
                    <Setter Property="Background" Value="{DynamicResource AccentInfoBackground}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CommitRefLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static git:CommitRefKind.RemoteBranch}">
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CommitRefOverflowStyle" TargetType="Border">
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderTertiary}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeaderItemStyle" TargetType="ListViewItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SectionHeaderTemplate">
            <Border Padding="0"
                    BorderBrush="{DynamicResource BorderTertiary}"
                    BorderThickness="0,0,0,1"
                    TextElement.FontFamily="{StaticResource FontFamilyUi}"
                    ToolTip="{Binding RemoteUrlDisplay}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource IncomingHeaderBackground}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource OutgoingHeaderBackground}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="3"
                            Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <Grid Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOutgoing}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentWarning}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="1"
                                   Text=" &#x2022; "
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Visibility="{Binding HasRemoteName, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding RemoteNameDisplay}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Visibility="{Binding HasRemoteName, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Grid.Column="3"
                                   Text=" &#x2022; "
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}"
                                   Visibility="{Binding HasRemoteUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Grid.Column="4"
                                   Text="{Binding RemoteUrlDisplay}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiary}"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding HasRemoteUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SectionEmptyRowTemplate">
            <Border Height="24"
                    BorderBrush="{DynamicResource BorderTertiary}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource BackgroundPrimary}"
                    TextElement.FontFamily="{StaticResource FontFamilyUi}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="142"/>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition Width="68"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="{Binding DataContext.GraphColumnWidth, RelativeSource={RelativeSource AncestorType=ListView}}"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Message}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="2,0,8,0"
                               FontSize="11"
                               FontStyle="Italic"
                               Foreground="{DynamicResource TextTertiary}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CommitRowTemplate">
            <Grid Height="24">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="TextElement.FontWeight" Value="Normal"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasHistoryEditOverlay}" Value="True">
                                <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="142"/>
                    <ColumnDefinition Width="104"/>
                    <ColumnDefinition Width="68"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Width="{Binding DataContext.GraphColumnWidth, RelativeSource={RelativeSource AncestorType=ListView}}"
                      ClipToBounds="True">
                    <local:CommitGraphCell GraphRow="{Binding GraphRow}"
                                           RemoteState="{Binding RemoteState}"
                                           IsSelectedRow="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"/>
                    <TextBlock Text="*" FontSize="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,1,0,0" Foreground="{DynamicResource AccentWarning}"
                               ToolTip="Same commit, rewritten. Push (force-with-lease) to replace the remote copy."
                               Visibility="{Binding IsOrphanedPair, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>

                <DockPanel Grid.Column="1" LastChildFill="True" Margin="2,0,8,0" VerticalAlignment="Center">
                    <ItemsControl DockPanel.Dock="Left"
                                  ItemsSource="{Binding VisibleRefLabels}"
                                  Visibility="{Binding HasVisibleRefLabels, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CommitRefLabelStyle}"
                                        ToolTip="{Binding Name}">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource CommitRefLabelTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border DockPanel.Dock="Left"
                            Style="{StaticResource CommitRefOverflowStyle}"
                            ToolTip="{Binding RefLabelsTooltip}"
                            Visibility="{Binding HasHiddenRefLabels, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding HiddenRefLabelText}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Border>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="8,0,0,0"
                                ToolTip="{Binding HistoryEditTooltip}"
                                Visibility="{Binding HasAnyHistoryEditIcon, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource AccentWarning}"
                              StrokeThickness="1.6"
                              Fill="Transparent"
                              Data="{StaticResource HistoryEditMessageGlyph}"
                              Margin="0,0,3,0"
                              Visibility="{Binding HasPendingMessageChange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource AccentWarning}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="{StaticResource HistoryEditAuthorGlyph}"
                              Margin="0,0,3,0"
                              Visibility="{Binding HasPendingAuthorChange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource AccentWarning}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="{StaticResource HistoryEditTimeGlyph}"
                              Margin="0,0,3,0"
                              Visibility="{Binding HasPendingTimeChange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource TextTertiary}"
                              StrokeThickness="1.4"
                              Fill="Transparent"
                              Data="{StaticResource HistoryEditFileGlyph}"
                              Margin="0,0,3,0"
                              Visibility="{Binding HasPendingFileChange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Path Width="12"
                              Height="12"
                              Stretch="Uniform"
                              Stroke="{DynamicResource AccentBlue}"
                              StrokeThickness="1.7"
                              Fill="Transparent"
                              Data="{StaticResource HistoryEditTransitiveGlyph}"
                              Margin="0,0,3,0"
                              Visibility="{Binding IsHistoryEditTransitive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                    <TextBlock VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CommitPrimaryTextStyle}">
                        <Run Text="{Binding DisplayMessage, Mode=OneWay}"/>
                        <InlineUIContainer BaselineAlignment="Center">
                            <Border Width="16"
                                    Height="16"
                                    CornerRadius="3"
                                    Margin="5,0,0,0"
                                    ToolTip="{Binding SigningBadgeTooltip}"
                                    Visibility="{Binding HasSigningBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundSecondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SigningStatus}" Value="Good">
                                                <Setter Property="Background" Value="{DynamicResource AccentSuccessBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SigningStatus}" Value="Bad">
                                                <Setter Property="Background" Value="{DynamicResource AccentDangerBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SigningStatus}" Value="Untrusted">
                                                <Setter Property="Background" Value="{DynamicResource AccentWarningBackground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SigningBadgeText}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </Border>
                        </InlineUIContainer>
                    </TextBlock>
                </DockPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <local:Avatar Email="{Binding DisplayAuthorEmail}" DisplayName="{Binding DisplayAuthorName}"
                                  Margin="0,0,5,0"
                                  Enabled="{Binding DataContext.Ui.GravatarEnabled, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                    <TextBlock Text="{Binding DisplayAuthorName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CommitSecondaryTextStyle}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" FontSize="11"
                               Style="{StaticResource CommitSecondaryTextStyle}">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource DateCellConverter}">
                                <Binding Path="DisplayDate"/>
                                <Binding Path="DataContext.Ui.UseRelativeDates"
                                         RelativeSource="{RelativeSource AncestorType=ListView}"/>
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.ToolTip>
                            <MultiBinding Converter="{StaticResource DateTooltipConverter}">
                                <Binding Path="DisplayDate"/>
                                <Binding Path="DataContext.Ui.UseRelativeDates"
                                         RelativeSource="{RelativeSource AncestorType=ListView}"/>
                            </MultiBinding>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <Path Width="11" Height="11"
                          Stretch="Uniform"
                          Fill="Transparent"
                          Stroke="{DynamicResource TextSecondary}"
                          StrokeThickness="1.4"
                          Data="M8,1.5 A6.5,6.5 0 1 0 8.01,1.5 M8,4.5 L8,8.5 L10.8,10.2"
                          Margin="5,0,0,0"
                          VerticalAlignment="Center"
                          ToolTip="{Binding CommitterDateTooltip}"
                          Visibility="{Binding HasDivergedCommitterDate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{Binding CommitId}" VerticalAlignment="Center"
                           Style="{StaticResource CommitMonoTextStyle}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="160" MinHeight="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundSecondary}"
                BorderBrush="{DynamicResource BorderTertiary}"
                BorderThickness="0,0,0,1"
                Padding="6,6,6,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <local:SearchBox Grid.Column="0"
                                     x:Name="SearchBoxControl"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Placeholder="Search commits"
                                     ToolTip="Examples: author:Name  message:&quot;fix bug&quot;  sha:abc  after:2026-01-01"/>

                    <ComboBox Grid.Column="1"
                              Width="132"
                              Height="28"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding ScopeOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Scope"
                              SelectedValue="{Binding SelectedScope, Mode=TwoWay}"
                              ToolTip="History scope"/>

                    <Border Grid.Column="2"
                            MinWidth="84"
                            Height="24"
                            Margin="8,2,0,2"
                            Padding="8,2"
                            CornerRadius="12"
                            Background="{DynamicResource BackgroundPrimary}"
                            BorderBrush="{DynamicResource BorderTertiary}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding HistoryStatusText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Border>

                    <Button Grid.Column="3"
                            Width="28" Height="28" Margin="6,0,0,0"
                            Command="{Binding ClearAllFiltersCommand}"
                            ToolTip="Reset filter"
                            AutomationProperties.Name="Reset history filter"
                            Visibility="{Binding HasActiveFilters, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource GhostButton}">
                        <Path Stretch="Uniform" Width="12" Height="12"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                              Fill="Transparent"
                              Data="M4,4 L16,16 M16,4 L4,16"/>
                    </Button>
                </Grid>

                <DockPanel Grid.Row="1" Margin="2,4,0,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding SelectedRefDisplayName, StringFormat=Ref: {0}}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBlue}"
                               Margin="8,0,0,0"
                               Visibility="{Binding IsNamedRefSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="author:Name  message:&quot;fix bug&quot;  sha:abc  after:2026-01-01"
                               FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>
        </Border>

        <ListView x:Name="CommitListBox"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedCommit, Mode=TwoWay}"
                  SelectionMode="Extended"
                  SelectionChanged="CommitListBox_SelectionChanged"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Item"
                  ScrollViewer.IsDeferredScrollingEnabled="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource SelectionBackgroundColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{DynamicResource SelectionTextColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{DynamicResource SelectionBackgroundColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource SelectionTextColor}"/>
            </ListView.Resources>

            <ListView.ItemContainerStyleSelector>
                <local:CommitContainerStyleSelector
                    CommitStyle="{StaticResource CommitItemStyle}"
                    HeaderStyle="{StaticResource SectionHeaderItemStyle}"/>
            </ListView.ItemContainerStyleSelector>

            <ListView.ItemTemplateSelector>
                <local:CommitRowTemplateSelector
                    CommitTemplate="{StaticResource CommitRowTemplate}"
                    HeaderTemplate="{StaticResource SectionHeaderTemplate}"
                    EmptyRowTemplate="{StaticResource SectionEmptyRowTemplate}"/>
            </ListView.ItemTemplateSelector>
        </ListView>

        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderTertiary}"
                      ResizeBehavior="PreviousAndNext"
                      helper:PersistedGridSplitter.Key="CommitListView.DiffHeight"
                      helper:PersistedGridSplitter.DefinitionKind="Row"
                      helper:PersistedGridSplitter.TargetIndex="3"/>

        <local:DiffView Grid.Row="3"
                        Header="{Binding DiffHeaderDisplay}"
                        Files="{Binding DiffFiles}"
                        RemoveChangeFromCommitCommand="{Binding RemoveChangeFromCommitCommand}"
                        FileTreeSplitterKey="CommitListView.DiffFileTreeWidth"/>
    </Grid>
</UserControl>
