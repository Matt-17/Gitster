<UserControl x:Class="Gitster.Controls.StatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Gitster.Controls"
             Height="26">
    <Border Background="{DynamicResource BackgroundSecondary}"
            BorderBrush="{DynamicResource BorderTertiary}"
            BorderThickness="0,0.5,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Cursor="Hand" Padding="10,0"
                    Background="Transparent" BorderThickness="0"
                    ToolTip="Open commit panel (Ctrl+K)"
                    AutomationProperties.Name="Open commit panel"
                    Command="{Binding DataContext.OpenCommitPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding StateIndicatorColor, Converter={StaticResource StatusColorToBrushConverter}}"/>
                    <TextBlock Text="{Binding StateText}" Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Button>

            <Grid Grid.Column="1" HorizontalAlignment="Center"
                  Visibility="{Binding HasFeedback, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <controls:RingSpinner Width="12" Height="12"
                                          Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding FeedbackIcon}"
                               FontSize="11"
                               Foreground="{Binding FeedbackColor, Converter={StaticResource StatusColorToBrushConverter}}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolVisibilityConverter}}"/>
                    <TextBlock Text="{Binding FeedbackText}" Margin="6,0,0,0"
                               FontSize="12"
                               Foreground="{Binding FeedbackColor, Converter={StaticResource StatusColorToBrushConverter}}"
                               VerticalAlignment="Center"/>
                    <Button Margin="6,0,0,0" Padding="2"
                            Background="Transparent" BorderThickness="0"
                            Width="16" Height="16"
                            Command="{Binding DismissFeedbackCommand}"
                            Visibility="{Binding IsFailure, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTip="Dismiss"
                            AutomationProperties.Name="Dismiss feedback">
                        <Path Stretch="Uniform" Width="8" Height="8"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                              Data="M2,2 L10,10 M10,2 L2,10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Column="2"
                    Padding="10,0"
                    BorderBrush="{DynamicResource BorderTertiary}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding HasSubmoduleStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding SubmoduleStatusText}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"/>
            </Border>

            <Button Grid.Column="3" Cursor="Hand" Padding="10,0"
                    Background="Transparent" BorderThickness="0"
                    Command="{Binding OpenRepositoryFolderCommand}"
                    ToolTip="{Binding RepositoryPath}"
                    AutomationProperties.Name="Open repository folder">
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Copy full path"
                                  Command="{Binding CopyRepositoryPathCommand}"/>
                    </ContextMenu>
                </Button.ContextMenu>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlueBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Width="12" Height="10" Margin="0,0,6,0"
                          Stretch="Uniform"
                          Fill="Transparent"
                          Stroke="{DynamicResource TextTertiary}"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          VerticalAlignment="Center"
                          Data="M2,5 V4 C2,3.45 2.45,3 3,3 H6.75 L8.25,4.5 H14 C14.55,4.5 15,4.95 15,5.5 V12 C15,12.55 14.55,13 14,13 H3 C2.45,13 2,12.55 2,12 Z"/>
                    <TextBlock Text="{Binding RepositoryPathDisplay}"
                               FontFamily="{DynamicResource FontFamilyMono}"
                               FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>
