<Application x:Class="Gitster.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Gitster"
             xmlns:converters="clr-namespace:Gitster.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.Light.xaml"/>
                <ResourceDictionary Source="Themes/Gitster.xaml"/>
                <ResourceDictionary Source="Themes/Icons.xaml"/>
                <ResourceDictionary Source="Themes/Buttons.xaml"/>
                <ResourceDictionary Source="Themes/Cards.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBoolVisibilityConverter x:Key="InverseBoolVisibilityConverter"/>
            <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
            <converters:RelativeDateConverter x:Key="RelativeDateConverter"/>
            <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
            <converters:StatusColorToBrushConverter x:Key="StatusColorToBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
