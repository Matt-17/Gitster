<Window x:Class="Gitster.Views.RangeTimestampDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Gitster.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:RangeTimestampViewModel}"
        Title="Rewrite timestamps – Gitster"
        Width="540" SizeToContent="Height"
        MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundPrimary}">

    <DockPanel Margin="20,16">

        <!-- ── Buttons ────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="_Cancel"
                    Style="{StaticResource DialogButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="OnCancel"/>
            <Button Content="{Binding RewriteButtonText}"
                    Style="{StaticResource DialogPrimaryButton}"
                    Command="{Binding RewriteCommand}"
                    IsEnabled="{Binding IsRewriteEnabled}"/>
        </StackPanel>

        <!-- ── Main content ───────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Section: commit range -->
                <TextBlock Text="Commit range"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{Binding LoadStatusText}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="From (oldest)"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Height="30"
                              ItemsSource="{Binding AllCommits}"
                              SelectedItem="{Binding FromCommit}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding CommitId, Mode=OneWay}"
                                         FontFamily="{StaticResource FontFamilyMono}"
                                         Foreground="{DynamicResource TextSecondary}"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding Message, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="To (newest)"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              Height="30"
                              ItemsSource="{Binding AllCommits}"
                              SelectedItem="{Binding ToCommit}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding CommitId, Mode=OneWay}"
                                         FontFamily="{StaticResource FontFamilyMono}"
                                         Foreground="{DynamicResource TextSecondary}"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding Message, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Divider -->
                <Border Height="0.5" Background="{DynamicResource BorderTertiary}" Margin="0,0,0,16"/>

                <!-- Section: shift offset -->
                <TextBlock Text="Shift all timestamps by offset"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Direction"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Content="Earlier"
                                     IsChecked="{Binding ShiftEarlier}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,20,0"/>
                        <RadioButton Content="Later"
                                     IsChecked="{Binding ShiftLater}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Amount"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60" Height="30"
                                 BorderBrush="{DynamicResource BorderTertiary}"
                                 BorderThickness="1"
                                 Background="{DynamicResource BackgroundPrimary}"
                                 Foreground="{DynamicResource TextPrimary}"/>
                        <ComboBox ItemsSource="{Binding UnitOptions}"
                                  SelectedItem="{Binding Unit}"
                                  Height="30" Width="80"
                                  Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Divider -->
                <Border Height="0.5" Background="{DynamicResource BorderTertiary}" Margin="0,0,0,16"/>

                <!-- Options -->
                <StackPanel Margin="0,0,0,12">
                    <CheckBox Content="Update author timestamp"
                              IsChecked="{Binding UpdateAuthorTimestamp}"
                              Foreground="{DynamicResource TextPrimary}"
                              Margin="0,0,0,6"/>
                    <CheckBox Content="Update committer timestamp"
                              IsChecked="{Binding UpdateCommitterTimestamp}"
                              Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <!-- Warning banner (OnRemote commits in range) -->
                <Border Visibility="{Binding HasUnsafeCommits,
                                             Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{DynamicResource AccentWarningBackground}"
                        BorderBrush="{DynamicResource AccentWarning}"
                        BorderThickness="0.5"
                        CornerRadius="{StaticResource CornerRadiusMd}"
                        Padding="10,7"
                        Margin="0,0,0,12">
                    <TextBlock TextWrapping="Wrap" FontSize="11">
                        <Run Text="⚠" Foreground="{DynamicResource AccentWarning}"/>
                        <Run Text=" Some commits in this range are already on the remote. Rewriting will require a force-push and will affect anyone who has pulled them."
                             Foreground="{DynamicResource TextPrimary}"/>
                    </TextBlock>
                </Border>

                <!-- Preview header -->
                <TextBlock FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8">
                    <Run Text="Preview ("/>
                    <Run Text="{Binding PreviewCount, Mode=OneWay}"/>
                    <Run Text=" commits):"/>
                </TextBlock>

                <!-- Preview list -->
                <Border BorderBrush="{DynamicResource BorderTertiary}"
                        BorderThickness="0.5"
                        CornerRadius="{StaticResource CornerRadiusMd}"
                        MaxHeight="220"
                        Margin="0,0,0,4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Preview}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Sha, Mode=OneWay}"
                                                   FontFamily="{StaticResource FontFamilyMono}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Message, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0"/>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding OriginalDate, StringFormat='dd.MM. HH:mm'}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextTertiary}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock FontSize="10"
                                                       Foreground="{DynamicResource AccentBlue}"
                                                       HorizontalAlignment="Right">
                                                <Run Text="→ "/>
                                                <Run Text="{Binding NewDate, StringFormat='dd.MM. HH:mm', Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
