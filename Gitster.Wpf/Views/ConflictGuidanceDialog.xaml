<Window x:Class="Gitster.Views.ConflictGuidanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Conflict guidance"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        MaxWidth="720"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        KeyboardNavigation.TabNavigation="Cycle">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundPrimary}"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CornerRadiusMd}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{DynamicResource AccentWarning}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CaptionText"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextOnAccent}"
                           FontWeight="SemiBold"
                           Text="Conflict guidance"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1"
                        Width="42"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextOnAccent}"
                        Click="OnCloseClicked"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="Close"
                        AutomationProperties.Name="Close conflict guidance">
                    <TextBlock Text="x"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="OperationText"
                           FontWeight="SemiBold"
                           FontSize="{DynamicResource FontSizeHeader}"
                           Foreground="{DynamicResource TextPrimary}"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="StateText"
                           Grid.Row="1"
                           Margin="0,10,0,0"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{DynamicResource FontSizeBase}"
                           TextWrapping="Wrap"/>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        BorderBrush="{DynamicResource BorderTertiary}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadiusSm}"
                        Background="{DynamicResource BackgroundSecondary}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="10,8,10,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Text="Conflicted files"/>
                        <ListBox x:Name="FilesList"
                                 Grid.Row="1"
                                 Margin="8,0,8,8"
                                 MaxHeight="140"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimary}"/>
                    </Grid>
                </Border>

                <TextBox x:Name="RawMessageText"
                         Grid.Row="3"
                         Margin="0,14,0,0"
                         MaxHeight="140"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="{DynamicResource FontSizeSmall}"
                         Foreground="{DynamicResource TextSecondary}"
                         Background="{DynamicResource BackgroundSecondary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="18,0,18,18">
                <Button x:Name="OpenMergeToolButton"
                        Content="Open _merge tool"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Click="OnOpenMergeToolClicked"/>
                <Button Content="_Retry"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Click="OnRetryClicked"/>
                <Button Content="Copy _list"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Click="OnCopyListClicked"/>
                <Button Content="Cl_ose"
                        Style="{StaticResource DialogButton}"
                        IsDefault="True"
                        IsCancel="True"
                        Click="OnCloseClicked"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
