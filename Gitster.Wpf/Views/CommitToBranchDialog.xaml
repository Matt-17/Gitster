<Window x:Class="Gitster.Views.CommitToBranchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Commit to another branch"
        Width="540" Height="540"
        MinWidth="480" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Target branch"
                   FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
        <ComboBox Grid.Row="2" x:Name="BranchCombo" IsEditable="True"
                  FontSize="13" Padding="6,4"/>

        <TextBlock Grid.Row="4" Text="Commit message"
                   FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
        <TextBox Grid.Row="6" x:Name="MessageBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="13"
                 Background="{DynamicResource BackgroundSecondary}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource BorderTertiary}"/>

        <!-- Author (optional; blank = repository default) -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Author name (optional)" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBox x:Name="AuthorNameBox" FontSize="13" Margin="0,4,0,0"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Author email (optional)" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"/>
                <TextBox x:Name="AuthorEmailBox" FontSize="13" Margin="0,4,0,0"
                         Background="{DynamicResource BackgroundSecondary}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderTertiary}"/>
            </StackPanel>
        </Grid>

        <!-- Which changes -->
        <StackPanel Grid.Row="10">
            <TextBlock Text="Which changes" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <RadioButton x:Name="StagedOnlyRadio" Content="Staged only" IsChecked="True"
                             GroupName="scope" Foreground="{DynamicResource TextPrimary}" Margin="0,0,16,0"/>
                <RadioButton x:Name="AllChangesRadio" Content="Staged + unstaged"
                             GroupName="scope" Foreground="{DynamicResource TextPrimary}"/>
            </StackPanel>
        </StackPanel>

        <CheckBox Grid.Row="12" x:Name="MoveCheck"
                  Content="Remove these changes from the current branch (move instead of copy)"
                  Foreground="{DynamicResource TextSecondary}" FontSize="12"/>

        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="_Cancel" Style="{DynamicResource DialogButton}"
                    Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Co_mmit" Style="{DynamicResource DialogPrimaryButton}"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
